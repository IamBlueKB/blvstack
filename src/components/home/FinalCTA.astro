---
---

<section class="relative overflow-hidden px-6 md:px-16 py-40">

  <!-- Animated gradient mesh -->
  <div
    class="pointer-events-none absolute inset-0"
    style="
      background:
        radial-gradient(ellipse 80% 60% at 20% 50%, rgba(37,99,235,0.14) 0%, transparent 60%),
        radial-gradient(ellipse 60% 80% at 80% 30%, rgba(30,64,175,0.12) 0%, transparent 55%),
        radial-gradient(ellipse 40% 40% at 60% 80%, rgba(37,99,235,0.07) 0%, transparent 50%);
    "
    aria-hidden="true"
  />

  <div class="absolute top-0 left-0 right-0 h-px bg-white/5" />

  <div class="relative max-w-7xl mx-auto flex flex-col items-start gap-16">

    <p class="font-mono text-xs tracking-widest uppercase text-electric">Ready?</p>

    <h2 class="text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight text-cream leading-[0.9]">
      Ready to build?
    </h2>

    <a
      href="/start"
      data-magnetic
      class="inline-flex items-center justify-center px-10 py-5 bg-electric text-cream font-mono text-sm tracking-widest uppercase hover:bg-royal transition-colors duration-300"
    >
      Start a Project
    </a>

    <p class="font-mono text-[10px] tracking-widest uppercase text-slate/40">
      No retainers. No bloat. Results or refund.
    </p>

  </div>

  <div class="absolute bottom-0 left-0 right-0 h-px bg-white/5" />

</section>
