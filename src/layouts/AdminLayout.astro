---
import '../styles/globals.css';

interface Props {
  title: string;
  adminEmail?: string;
  hideNav?: boolean;
  active?: 'overview' | 'leads' | 'messages' | 'trash' | 'settings';
}

const { title, adminEmail, hideNav = false, active } = Astro.props;
const pageTitle = `${title} — BLVSTACK Console`;

type NavItem = {
  key: string;
  label: string;
  href: string;
  n: string;
  children?: { key: string; label: string; href: string }[];
};

const navItems: NavItem[] = [
  { key: 'overview', label: 'Overview', href: '/admin',          n: '01' },
  { key: 'leads',    label: 'Leads',    href: '/admin/leads',    n: '02' },
  {
    key: 'messages',
    label: 'Messages',
    href: '/admin/messages',
    n: '03',
    children: [
      { key: 'trash', label: 'Trash', href: '/admin/trash' },
    ],
  },
  { key: 'settings', label: 'Settings', href: '/admin/settings', n: '04' },
];

// Auto-detect active from path if not passed
const path = Astro.url.pathname;
const resolvedActive =
  active ??
  (path === '/admin' || path === '/admin/'
    ? 'overview'
    : path.startsWith('/admin/leads')
    ? 'leads'
    : path.startsWith('/admin/messages')
    ? 'messages'
    : path.startsWith('/admin/trash')
    ? 'trash'
    : path.startsWith('/admin/settings')
    ? 'settings'
    : undefined);
---

<!doctype html>
<html lang="en" class="bg-navy text-cream">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive, nosnippet" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:global>
      html, body, * { cursor: auto !important; }
      a, button, [role="button"], select, summary { cursor: pointer !important; }
      input, textarea { cursor: text !important; }
    </style>
  </head>

  <body class="min-h-screen bg-navy text-cream antialiased font-sans">

    {hideNav ? (
      <main class="min-h-screen">
        <slot />
      </main>
    ) : (
      <div class="flex min-h-screen">

        <!-- ════════ SIDEBAR ════════ -->
        <aside class="hidden md:flex w-60 lg:w-64 shrink-0 flex-col bg-navy border-r border-white/5 fixed inset-y-0 left-0 z-10">

          <!-- Brand -->
          <div class="px-6 py-6 border-b border-white/5">
            <a href="/admin" class="block hover:opacity-70 transition-opacity">
              <p class="font-bold tracking-tight text-cream text-lg leading-none">
                BLVST<span class="inline-block" aria-hidden="true">Λ</span>CK
              </p>
              <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mt-1.5">
                // Console
              </p>
            </a>
          </div>

          <!-- Nav -->
          <nav class="flex-1 flex flex-col gap-px p-3">
            {navItems.map((item) => {
              const isActive = resolvedActive === item.key;
              const childActive = item.children?.some((c) => c.key === resolvedActive) ?? false;
              const hasChildren = (item.children?.length ?? 0) > 0;
              // Open the group if the parent OR any child is active
              const groupOpen = isActive || childActive;
              return (
                <div class="flex flex-col">
                  <a
                    href={item.href}
                    class={`group flex items-center gap-3 px-3 py-2.5 transition-colors ${
                      isActive
                        ? 'bg-white/[0.06] text-cream'
                        : 'text-slate hover:bg-white/[0.03] hover:text-cream'
                    }`}
                  >
                    <span class={`font-mono text-[9px] tracking-widest ${
                      isActive || childActive ? 'text-electric' : 'text-slate/50 group-hover:text-electric'
                    }`}>
                      {item.n}
                    </span>
                    <span class="font-mono text-[11px] tracking-widest uppercase">
                      {item.label}
                    </span>
                    {isActive && (
                      <span class="ml-auto w-1.5 h-1.5 rounded-full bg-electric"></span>
                    )}
                    {hasChildren && !isActive && (
                      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class={`ml-auto transition-transform duration-200 ${groupOpen ? 'rotate-90' : ''}`} aria-hidden="true">
                        <path d="M3 1L7 5L3 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
                      </svg>
                    )}
                  </a>
                  {hasChildren && groupOpen && (
                    <div class="flex flex-col gap-px pl-6 mt-px">
                      {item.children!.map((child) => {
                        const childIsActive = resolvedActive === child.key;
                        return (
                          <a
                            href={child.href}
                            class={`group flex items-center gap-3 px-3 py-2 transition-colors border-l border-white/5 ${
                              childIsActive
                                ? 'bg-white/[0.04] text-cream border-l-electric'
                                : 'text-slate hover:bg-white/[0.03] hover:text-cream hover:border-l-white/20'
                            }`}
                          >
                            <span class={`font-mono text-[8px] tracking-widest ${
                              childIsActive ? 'text-electric' : 'text-slate/40'
                            }`}>
                              ↳
                            </span>
                            <span class="font-mono text-[10px] tracking-widest uppercase">
                              {child.label}
                            </span>
                            {childIsActive && (
                              <span class="ml-auto w-1 h-1 rounded-full bg-electric"></span>
                            )}
                          </a>
                        );
                      })}
                    </div>
                  )}
                </div>
              );
            })}
          </nav>

          <!-- Footer block: identity + sign out -->
          <div class="p-3 border-t border-white/5">
            <div class="flex flex-col gap-2 px-3 py-3">
              <p class="font-mono text-[9px] tracking-widest uppercase text-slate/50">
                Signed in
              </p>
              <p class="font-mono text-[11px] text-cream truncate">
                {adminEmail}
              </p>
              <form method="POST" action="/api/admin/logout" class="mt-2">
                <button type="submit" class="w-full text-left font-mono text-[10px] tracking-widest uppercase text-slate hover:text-electric transition-colors">
                  Sign out &rarr;
                </button>
              </form>
            </div>
          </div>

        </aside>

        <!-- ════════ MOBILE TOP BAR ════════ -->
        <div class="md:hidden fixed inset-x-0 top-0 z-20 bg-navy border-b border-white/5">
          <div class="flex items-center justify-between px-4 h-12">
            <a href="/admin" class="font-bold tracking-tight text-cream text-sm">
              BLVST<span class="inline-block" aria-hidden="true">Λ</span>CK
              <span class="text-slate font-mono font-normal text-[9px] tracking-widest uppercase ml-1">// Console</span>
            </a>
            <button id="mobile-nav-toggle" aria-label="Open menu" class="text-cream p-1">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6" />
                <line x1="3" y1="12" x2="21" y2="12" />
                <line x1="3" y1="18" x2="21" y2="18" />
              </svg>
            </button>
          </div>

          <!-- Mobile menu drawer -->
          <div id="mobile-nav-drawer" class="hidden border-t border-white/5">
            <nav class="flex flex-col">
              {navItems.map((item) => {
                const isActive = resolvedActive === item.key;
                return (
                  <>
                    <a
                      href={item.href}
                      class={`flex items-center gap-3 px-4 py-3 border-b border-white/5 ${
                        isActive ? 'text-electric' : 'text-cream'
                      }`}
                    >
                      <span class="font-mono text-[9px] tracking-widest text-slate/50">{item.n}</span>
                      <span class="font-mono text-[11px] tracking-widest uppercase">{item.label}</span>
                    </a>
                    {item.children?.map((child) => {
                      const childIsActive = resolvedActive === child.key;
                      return (
                        <a
                          href={child.href}
                          class={`flex items-center gap-3 pl-10 pr-4 py-3 border-b border-white/5 ${
                            childIsActive ? 'text-electric' : 'text-slate'
                          }`}
                        >
                          <span class="font-mono text-[8px] tracking-widest text-slate/40">↳</span>
                          <span class="font-mono text-[10px] tracking-widest uppercase">{child.label}</span>
                        </a>
                      );
                    })}
                  </>
                );
              })}
              <form method="POST" action="/api/admin/logout" class="px-4 py-3">
                <button type="submit" class="font-mono text-[10px] tracking-widest uppercase text-slate hover:text-electric transition-colors">
                  Sign out &rarr;
                </button>
              </form>
            </nav>
          </div>
        </div>

        <!-- ════════ MAIN ════════ -->
        <main class="flex-1 md:ml-60 lg:ml-64 pt-14 md:pt-0 min-h-screen">
          <div class="max-w-6xl px-6 md:px-10 py-10">
            <slot />
          </div>
        </main>

      </div>
    )}

    <script>
      const toggle = document.getElementById('mobile-nav-toggle');
      const drawer = document.getElementById('mobile-nav-drawer');
      if (toggle && drawer) {
        toggle.addEventListener('click', () => {
          drawer.classList.toggle('hidden');
        });
      }
    </script>

  </body>
</html>
