---
import Base from '../../layouts/Base.astro';

const TITLE = 'PSRx Body & Skin — Case Study';
const DESC = 'A clinical skin intelligence platform — AI-driven assessment, members-only Skin Intelligence Portal, monthly protocols supervised by the clinical team.';

// Build features — what we shipped (capability claims, no metrics)
const FEATURES = [
  {
    code: 'F1',
    title: 'Skin Assessment Intake',
    body: 'AI-driven intake that scores skin type, primary concerns, and Fitzpatrick classification on submit. Outputs become the input for a personalized monthly protocol — reviewed and approved by the clinical NP team before it reaches the patient.',
  },
  {
    code: 'F2',
    title: 'Skin Intelligence Portal',
    body: 'Members-only experience built around the protocol. Monthly check-ins (full + micro) re-scored for progression, member pricing on the in-house product line, in-clinic booking, and a private content library.',
  },
  {
    code: 'F3',
    title: 'Membership Engine',
    body: 'Recurring subscription system with founding-member and standard tiers. Stripe-powered billing, automated lifecycle events, and gating that ties access to assessment completion — no half-onboarded members.',
  },
  {
    code: 'F4',
    title: 'Replenishment + Matching',
    body: 'Category-aware reorder reminders (cleansers 45d, serums 60d, retinoids 90d, etc.) and AI-recommended product matching tied to assessment history. A clinic that keeps showing up between visits.',
  },
];

---

<Base title={TITLE} description={DESC} ogImage="/og/work-psrx-body-and-skin.png">

  <!-- ════════════════ HERO ════════════════ -->
  <section class="relative pt-48 pb-24 px-6 md:px-12 lg:px-16 max-w-7xl mx-auto">

    <!-- Eyebrow -->
    <div class="flex items-center gap-4 mb-10 opacity-0 animate-fade-up" style="animation-delay: 0.1s;">
      <span class="h-px w-10 bg-electric"></span>
      <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-electric">
        // Case Study
      </span>
      <span class="font-mono text-[11px] tracking-widest uppercase text-slate/70">
        CS2 · Platform
      </span>
    </div>

    <!-- Editorial title -->
    <h1 class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold tracking-tight text-cream leading-[0.95] max-w-5xl opacity-0 animate-fade-up" style="animation-delay: 0.25s;">
      An AI skin platform<br />
      <span class="text-electric">for a clinical practice.</span>
    </h1>

    <!-- Supporting -->
    <p class="mt-14 text-base md:text-lg text-slate leading-relaxed max-w-xl opacity-0 animate-fade-up" style="animation-delay: 0.4s;">
      A members-only Skin Intelligence Platform for a working aesthetics clinic — AI assessment, monthly protocols, recurring subscription, and in-house product fulfillment. Built so the patient relationship doesn't end at the door.
    </p>

    <!-- Meta grid -->
    <div class="mt-16 grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5 max-w-3xl opacity-0 animate-fade-up" style="animation-delay: 0.55s;">
      <div class="bg-navy p-5">
        <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mb-2">Client</p>
        <p class="font-mono text-xs text-cream">PSRx Body & Skin</p>
      </div>
      <div class="bg-navy p-5">
        <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mb-2">Industry</p>
        <p class="font-mono text-xs text-cream">Medical Aesthetics</p>
      </div>
      <div class="bg-navy p-5">
        <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mb-2">Timeline</p>
        <p class="font-mono text-xs text-cream">6 weeks</p>
      </div>
      <div class="bg-navy p-5">
        <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mb-2">Status</p>
        <p class="font-mono text-xs text-electric flex items-center gap-2">
          <span class="relative flex w-1.5 h-1.5">
            <span class="absolute inset-0 rounded-full bg-electric animate-ping opacity-75"></span>
            <span class="relative w-1.5 h-1.5 rounded-full bg-electric"></span>
          </span>
          Live
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════ PROBLEM ════════════════ -->
  <section class="px-6 md:px-12 lg:px-16 py-16 max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16">

      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex flex-col gap-[2px]" aria-hidden="true" style="width: 14px;">
            <span class="block h-[1.5px] w-full bg-electric"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
          </span>
          <span class="font-mono text-[11px] tracking-widest uppercase text-slate">
            01 · Problem
          </span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-cream leading-tight">
          An old website.<br />
          <span class="text-electric">A real product.</span>
        </h2>
      </div>

      <div class="md:col-span-7 flex flex-col gap-6 max-w-2xl">
        <p class="text-base md:text-lg text-cream/85 leading-relaxed">
          PSRx Body & Skin operates two clinics, a growing in-house product line, and a skin-assessment process the team was running by hand. The legacy site couldn't carry any of that — no member layer, no way to gate the assessment, no path from a one-time visit to a recurring relationship.
        </p>
        <p class="text-base md:text-lg text-slate leading-relaxed">
          Most med-spa sites stop at "book a consultation." A clinic operating at this level needed an actual platform — one that captured the patient, scored their skin, returned a real protocol, and renewed itself every month.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════ APPROACH ════════════════ -->
  <section class="px-6 md:px-12 lg:px-16 py-16 max-w-7xl mx-auto border-t border-white/5">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16">

      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex flex-col gap-[2px]" aria-hidden="true" style="width: 14px;">
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-electric"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
          </span>
          <span class="font-mono text-[11px] tracking-widest uppercase text-slate">
            02 · Approach
          </span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-cream leading-tight">
          A platform,<br />
          <span class="text-electric">not a brochure.</span>
        </h2>
      </div>

      <div class="md:col-span-7 flex flex-col gap-6 max-w-2xl">
        <p class="text-base md:text-lg text-cream/85 leading-relaxed">
          We anchored the experience around the assessment — a clinical intake the patient takes seriously because the clinic does. The public site does one job: drive into the assessment. The portal does the rest. Every page earns a position in the funnel.
        </p>
        <p class="text-base md:text-lg text-slate leading-relaxed">
          The AI sits inside a clinical loop. Claude scores intake and monthly check-ins; the NP team reviews and approves the protocol before it ships. The patient gets speed and personalization without the clinic ever losing oversight of what goes out.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════ BUILD ════════════════ -->
  <section class="px-6 md:px-12 lg:px-16 py-16 max-w-7xl mx-auto border-t border-white/5">
    <div class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="inline-flex flex-col gap-[2px]" aria-hidden="true" style="width: 14px;">
          <span class="block h-[1.5px] w-full bg-slate/40"></span>
          <span class="block h-[1.5px] w-full bg-slate/40"></span>
          <span class="block h-[1.5px] w-full bg-electric"></span>
          <span class="block h-[1.5px] w-full bg-slate/40"></span>
          <span class="block h-[1.5px] w-full bg-slate/40"></span>
        </span>
        <span class="font-mono text-[11px] tracking-widest uppercase text-slate">
          03 · Build
        </span>
      </div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-cream leading-tight max-w-3xl">
        What we shipped.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/5">
      {FEATURES.map((f) => (
        <article
          class="feature-card relative bg-navy overflow-hidden p-8 md:p-10 group"
          style="transform-style: preserve-3d;"
        >
          <!-- Hover sheen -->
          <div
            class="pointer-events-none absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700"
            style="background: radial-gradient(ellipse 60% 80% at 50% 0%, rgba(37,99,235,0.10) 0%, transparent 60%);"
            aria-hidden="true"
          ></div>

          <div class="relative z-10 flex items-center justify-between mb-6">
            <span class="font-mono text-[11px] tracking-widest uppercase text-slate/60">
              {f.code} · {f.title}
            </span>
            <span class="w-6 h-px bg-electric/40 group-hover:w-12 group-hover:bg-electric transition-all duration-500"></span>
          </div>
          <h3 class="relative z-10 text-2xl font-bold text-cream tracking-tight mb-4">{f.title}</h3>
          <p class="relative z-10 text-base text-slate leading-relaxed">{f.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- ════════════════ SELECTED SCREENS ════════════════ -->
  <section class="px-6 md:px-12 lg:px-16 py-16 max-w-7xl mx-auto border-t border-white/5">

    <div class="flex flex-col gap-3 mb-12 opacity-0 animate-fade-up" style="animation-delay: 0.1s;">
      <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-electric">
        // Selected screens
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-cream leading-[0.95] max-w-3xl">
        Where clinical meets <span class="text-electric">conversational.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-10">

      <figure class="flex flex-col gap-3 opacity-0 animate-fade-up" style="animation-delay: 0.25s;">
        <div class="border border-white/10 overflow-hidden bg-cream/[0.02]">
          <img
            src="/case-studies/psrx-body-and-skin-1.jpg"
            alt="PSRx Body & Skin — public site, brand-led landing"
            loading="lazy"
            class="w-full h-auto object-cover object-top block"
          />
        </div>
        <figcaption class="font-mono text-[10px] tracking-widest uppercase text-slate/70">
          // Public site — brand and conversion
        </figcaption>
      </figure>

      <figure class="flex flex-col gap-3 opacity-0 animate-fade-up" style="animation-delay: 0.4s;">
        <div class="border border-white/10 overflow-hidden bg-cream/[0.02]">
          <img
            src="/case-studies/psrx-body-and-skin-2.jpg"
            alt="PSRx Body & Skin — members-only Skin Intelligence Portal"
            loading="lazy"
            class="w-full h-auto object-cover object-top block"
          />
        </div>
        <figcaption class="font-mono text-[10px] tracking-widest uppercase text-slate/70">
          // Skin Intelligence Portal — member layer
        </figcaption>
      </figure>

    </div>
  </section>

  <!-- ════════════════ OUTCOME ════════════════ -->
  <section class="px-6 md:px-12 lg:px-16 py-16 max-w-7xl mx-auto border-t border-white/5">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16">
      <div class="md:col-span-5">
        <div class="flex items-center gap-3 mb-6">
          <span class="inline-flex flex-col gap-[2px]" aria-hidden="true" style="width: 14px;">
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
            <span class="block h-[1.5px] w-full bg-electric"></span>
            <span class="block h-[1.5px] w-full bg-slate/40"></span>
          </span>
          <span class="font-mono text-[11px] tracking-widest uppercase text-slate">
            04 · Outcome
          </span>
        </div>
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-cream leading-tight">
          A members-only<br />
          <span class="text-electric">clinical platform.</span>
        </h2>
      </div>

      <div class="md:col-span-7 flex flex-col gap-6 max-w-2xl">
        <p class="text-base md:text-lg text-cream/85 leading-relaxed">
          PSRx Body & Skin launched with a working assessment, a gated Skin Intelligence Portal, a recurring subscription tier, and integrated product fulfillment. The site captures patients the staff used to lose between visits and runs a relationship long after the in-clinic appointment ends.
        </p>
        <p class="text-base md:text-lg text-slate leading-relaxed">
          What launched is a system, not a website. New protocols, new check-in cadences, new product tiers — all configuration, not a rebuild.
        </p>
      </div>
    </div>
  </section>

  <!-- ════════════════ CTA ════════════════ -->
  <section class="relative overflow-hidden px-6 md:px-12 lg:px-16 py-40">
    <div
      class="pointer-events-none absolute inset-0"
      style="
        background:
          radial-gradient(ellipse 80% 60% at 20% 50%, rgba(37,99,235,0.14) 0%, transparent 60%),
          radial-gradient(ellipse 60% 80% at 80% 30%, rgba(30,64,175,0.12) 0%, transparent 55%);
      "
      aria-hidden="true"
    ></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-white/5"></div>

    <div class="relative max-w-7xl mx-auto flex flex-col items-start gap-10">
      <div class="flex items-center gap-4">
        <span class="h-px w-10 bg-electric"></span>
        <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-electric">
          // Ready
        </span>
      </div>

      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-cream leading-[0.92] max-w-3xl">
        Have a similar problem?<br />
        <span class="text-electric">Let's build the system.</span>
      </h2>

      <a
        href="/start"
        class="cta-primary group mt-4"
        data-magnetic
      >
        <span class="cta-primary-inner">
          <span class="cta-label">Start a Project</span>
          <svg class="cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
          </svg>
        </span>
      </a>

      <a
        href="/work"
        class="font-mono text-xs tracking-widest uppercase text-slate hover:text-electric transition-colors duration-300 inline-flex items-center gap-2"
      >
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
          <path d="M13 5H1M1 5L5 9M1 5L5 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
        </svg>
        Back to all work
      </a>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-px bg-white/5"></div>
  </section>

</Base>

<script is:inline>
  // 3D cursor tilt on feature + stack cards
  (() => {
    const cards = document.querySelectorAll('.feature-card');
    cards.forEach((card) => {
      let tx = 0, ty = 0;
      let targetX = 0, targetY = 0;
      let raf = 0;
      let active = false;
      const loop = () => {
        tx += (targetX - tx) * 0.18;
        ty += (targetY - ty) * 0.18;
        card.style.transform = `perspective(1200px) rotateX(${tx.toFixed(2)}deg) rotateY(${ty.toFixed(2)}deg)`;
        if (active || Math.abs(tx) > 0.05 || Math.abs(ty) > 0.05) {
          raf = requestAnimationFrame(loop);
        } else {
          card.style.transform = '';
        }
      };
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        const dx = ((e.clientX - r.left) / r.width - 0.5) * 2;
        const dy = ((e.clientY - r.top) / r.height - 0.5) * 2;
        targetX = -dy * 4;
        targetY = dx * 4;
        if (!active) {
          active = true;
          raf = requestAnimationFrame(loop);
        }
      });
      card.addEventListener('mouseleave', () => {
        active = false;
        targetX = 0;
        targetY = 0;
      });
    });
  })();
</script>

<style>
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-up { animation: none; opacity: 1; }
  }

  /* Reuse hero CTA styles */
  .cta-primary {
    position: relative;
    display: inline-flex;
    isolation: isolate;
    border: 1px solid rgba(37, 99, 235, 0.6);
    background: linear-gradient(180deg, #2D72FF 0%, #2563EB 45%, #1E40AF 100%);
    box-shadow:
      0 0 0 1px rgba(37, 99, 235, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.20),
      inset 0 -1px 0 rgba(0, 0, 0, 0.25),
      0 0 24px rgba(37, 99, 235, 0.45),
      0 0 60px rgba(37, 99, 235, 0.25);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-primary-inner {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 2rem;
    color: #FAF8F3;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .cta-primary .cta-arrow {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px rgba(37, 99, 235, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3),
      0 0 36px rgba(37, 99, 235, 0.7),
      0 0 100px rgba(37, 99, 235, 0.4);
  }
  .cta-primary:hover .cta-arrow {
    transform: translateX(3px);
  }
</style>
