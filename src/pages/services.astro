---
import Base from '../layouts/Base.astro';
import Brand from '../components/Brand.astro';

const TITLE = 'Services — BLVSTACK';
const DESC = 'Three layers, one system. What BLVSTACK builds: AI agents, automation systems, and AI-native websites — scoped end-to-end.';

const PILLARS = [
  {
    code: 'L1',
    tag: 'AGENTS',
    layerIndex: 0,
    slug: 'agents',
    label: 'AI Agents',
    headline: 'Conversational systems that handle real work.',
    overview: 'Chat, voice, booking, qualification, follow-up — we build agents that handle live conversations with real prospects, automatically. Tuned to your offer, your tone, your operating constraints.',
    included: [
      'Custom agent persona + system prompt',
      'Tool-use integrations (CRM, calendar, billing)',
      'Multi-turn follow-up sequences',
      'Rate limiting + conversation logging',
      'Voice agents for inbound + outbound calls',
    ],
    ideal: 'Founders and service businesses where qualification and intake currently bottleneck on human bandwidth.',
    timeline: '2–4 week build · live in production',
    outcomes: [
      'Inbound qualification runs without staff',
      'Booked meetings flow into the calendar continuously',
      'Conversation history captured for review and tuning',
    ],
  },
  {
    code: 'L2',
    tag: 'SYSTEMS',
    layerIndex: 1,
    slug: 'systems',
    label: 'Automation Systems',
    headline: 'Workflows that replace manual tasks entirely.',
    overview: 'We map your operations, find the bottlenecks, and build the automation layer that runs them without you. Event-driven, observable, and owned by you — not duct-taped together with no-code subscriptions.',
    included: [
      'Workflow audit + bottleneck mapping',
      'Event-driven triggers across your stack',
      'Document + email automation',
      'Lead routing + scoring logic',
      'Status sync between systems',
    ],
    ideal: 'Service operations doing repetitive admin — agencies, professional services, clinics, e-commerce.',
    timeline: '2–4 week build · phased rollout',
    outcomes: [
      'Manual work moves to scheduled background jobs',
      'Admin overhead stops scaling with revenue',
      'Adding capacity becomes configuration, not hiring',
    ],
  },
  {
    code: 'L3',
    tag: 'INTERFACES',
    layerIndex: 2,
    slug: 'interfaces',
    label: 'AI-Native Websites',
    headline: 'Sites with agents built in, not bolted on.',
    overview: 'Not a chatbot stuck in the corner. Intelligent interfaces designed to qualify, convert, and follow up — built into the site architecture from day one. Editorial design, premium craft, AI woven into the experience.',
    included: [
      'Custom marketing site, design + build',
      'Embedded intake / qualification agents',
      'Gated portals (customer, member, partner, or staff)',
      'Lead capture + CRM-synced pipelines',
      'CMS for structured content + ongoing edits',
    ],
    ideal: 'Founders launching a premium product or service who need a site that does more than describe — it has to operate.',
    timeline: '2–4 week build · launch-ready',
    outcomes: [
      'Site behaves like a sales rep, not a brochure',
      'Qualified leads land pre-vetted in the queue',
      'Brand and operating system arrive together',
    ],
  },
];
---

<Base title={TITLE} description={DESC}>

  <!-- ════════════════ HERO ════════════════ -->
  <section class="relative pt-48 pb-20 px-6 md:px-12 lg:px-16 max-w-7xl mx-auto">

    <div class="flex items-center gap-4 mb-10 opacity-0 animate-fade-up" style="animation-delay: 0.1s;">
      <span class="h-px w-10 bg-electric"></span>
      <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-electric">
        // Services
      </span>
    </div>

    <h1 class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold tracking-tight text-cream leading-[0.95] max-w-5xl opacity-0 animate-fade-up" style="animation-delay: 0.25s;">
      Three layers.<br />
      <span class="text-electric">One operating system.</span>
    </h1>

    <p class="mt-14 text-base md:text-lg text-slate leading-relaxed max-w-xl opacity-0 animate-fade-up" style="animation-delay: 0.4s;">
      Every <Brand /> engagement runs on the same architecture — three connected layers that turn manual work into a system. Most projects need one. Some need all three.
    </p>
  </section>

  <!-- ════════════════ PILLAR SECTIONS ════════════════ -->
  {PILLARS.map((p, i) => (
    <section class={`relative px-6 md:px-12 lg:px-16 py-24 md:py-32 max-w-7xl mx-auto ${i > 0 ? 'border-t border-white/5' : ''}`}>

      <!-- Layer header -->
      <div class="flex items-center gap-3 mb-10">
        <span class="inline-flex flex-col gap-[2px]" aria-hidden="true" style="width: 14px;">
          <span class={`block h-[1.5px] w-full ${p.layerIndex === 0 ? 'bg-electric' : 'bg-slate/40'}`}></span>
          <span class={`block h-[1.5px] w-full ${p.layerIndex === 1 ? 'bg-electric' : 'bg-slate/40'}`}></span>
          <span class={`block h-[1.5px] w-full ${p.layerIndex === 2 ? 'bg-electric' : 'bg-slate/40'}`}></span>
        </span>
        <span class="font-mono text-[11px] tracking-widest uppercase text-slate">
          {p.code} · {p.tag}
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-16">

        <!-- LEFT — title + overview -->
        <div class="md:col-span-7 flex flex-col gap-8">
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-cream leading-[0.95]">
            {p.label}
          </h2>

          <p class="text-2xl md:text-3xl font-bold text-electric tracking-tight leading-tight max-w-2xl">
            {p.headline}
          </p>

          <p class="text-base md:text-lg text-slate leading-relaxed max-w-2xl">
            {p.overview}
          </p>

          <!-- CTA -->
          <a
            href={`/start?service=${p.slug}`}
            class="cta-primary group self-start mt-4"
            data-magnetic
          >
            <span class="cta-primary-inner">
              <span class="cta-label">Start an {p.code} project</span>
              <svg class="cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
              </svg>
            </span>
          </a>
        </div>

        <!-- RIGHT — structured detail -->
        <div class="md:col-span-5 flex flex-col gap-px bg-white/5 self-start">

          <!-- What's included -->
          <div class="bg-navy p-6 md:p-8">
            <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">
              What's included
            </p>
            <ul class="space-y-3">
              {p.included.map((item) => (
                <li class="flex items-start gap-3 text-sm text-cream/85 leading-relaxed">
                  <span class="mt-[8px] w-3 h-px bg-electric/60 shrink-0"></span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Ideal client -->
          <div class="bg-navy p-6 md:p-8">
            <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mb-3">
              Ideal client
            </p>
            <p class="text-sm text-cream/85 leading-relaxed">
              {p.ideal}
            </p>
          </div>

          <!-- Timeline -->
          <div class="bg-navy p-6 md:p-8">
            <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mb-3">
              Timeline
            </p>
            <p class="font-mono text-sm text-cream">
              {p.timeline}
            </p>
          </div>

          <!-- Example outcomes -->
          <div class="bg-navy p-6 md:p-8">
            <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mb-3">
              Example outcomes
            </p>
            <ul class="space-y-2">
              {p.outcomes.map((o) => (
                <li class="flex items-start gap-3 text-sm text-cream/80 leading-relaxed">
                  <span class="text-electric/80 mt-[2px]">→</span>
                  <span>{o}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- ════════════════ NOT SURE WHICH? ════════════════ -->
  <section class="px-6 md:px-12 lg:px-16 py-24 max-w-7xl mx-auto border-t border-white/5">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
      <div>
        <p class="font-mono text-[11px] tracking-widest uppercase text-electric mb-4">
          // Unsure where you fit?
        </p>
        <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-cream max-w-xl leading-tight">
          Most projects start as one layer and grow into the system.
        </h3>
      </div>
      <a
        href="/start"
        class="font-mono text-xs tracking-[0.25em] uppercase text-cream hover:text-electric transition-colors duration-300 inline-flex items-center gap-3 self-start"
      >
        Apply for scoping
        <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
          <path d="M1 5H13M13 5L9 1M13 5L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
        </svg>
      </a>
    </div>
  </section>

  <!-- ════════════════ CTA ════════════════ -->
  <section class="relative overflow-hidden px-6 md:px-12 lg:px-16 py-40 border-t border-white/5">
    <div
      class="pointer-events-none absolute inset-0"
      style="
        background:
          radial-gradient(ellipse 80% 60% at 20% 50%, rgba(37,99,235,0.14) 0%, transparent 60%),
          radial-gradient(ellipse 60% 80% at 80% 30%, rgba(30,64,175,0.12) 0%, transparent 55%);
      "
      aria-hidden="true"
    ></div>

    <div class="relative max-w-7xl mx-auto flex flex-col items-start gap-10">
      <div class="flex items-center gap-4">
        <span class="h-px w-10 bg-electric"></span>
        <span class="font-mono text-[11px] tracking-[0.25em] uppercase text-electric">
          // Ready
        </span>
      </div>

      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-cream leading-[0.92] max-w-3xl">
        Tell us what you're<br />
        <span class="text-electric">trying to solve.</span>
      </h2>

      <a href="/start" class="cta-primary group" data-magnetic>
        <span class="cta-primary-inner">
          <span class="cta-label">Start a Project</span>
          <svg class="cta-arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M1 7H13M13 7L7 1M13 7L7 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" />
          </svg>
        </span>
      </a>
    </div>
  </section>

</Base>

<style>
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up {
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-up { animation: none; opacity: 1; }
  }

  .cta-primary {
    position: relative;
    display: inline-flex;
    isolation: isolate;
    border: 1px solid rgba(37, 99, 235, 0.6);
    background: linear-gradient(180deg, #2D72FF 0%, #2563EB 45%, #1E40AF 100%);
    box-shadow:
      0 0 0 1px rgba(37, 99, 235, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.20),
      inset 0 -1px 0 rgba(0, 0, 0, 0.25),
      0 0 24px rgba(37, 99, 235, 0.45),
      0 0 60px rgba(37, 99, 235, 0.25);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-primary-inner {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 2rem;
    color: #FAF8F3;
    font-family: var(--font-mono, ui-monospace, monospace);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .cta-primary .cta-arrow {
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .cta-primary:hover {
    transform: translateY(-1px);
    box-shadow:
      0 0 0 1px rgba(37, 99, 235, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.28),
      inset 0 -1px 0 rgba(0, 0, 0, 0.3),
      0 0 36px rgba(37, 99, 235, 0.7),
      0 0 100px rgba(37, 99, 235, 0.4);
  }
  .cta-primary:hover .cta-arrow {
    transform: translateX(3px);
  }
</style>
