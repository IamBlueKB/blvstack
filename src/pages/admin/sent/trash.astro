---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { listSentEmails } from '../../../lib/janet/sent';

export const prerender = false;

const adminEmail = Astro.locals.adminEmail;
const { rows: emails, total } = await listSentEmails({ trashed: true, pageSize: 200 });

function fmt(iso: string): string {
  const d = new Date(iso);
  return `${d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })} · ${d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}`;
}
---

<AdminLayout title="Sent · Trash" adminEmail={adminEmail} active="sent">

  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-2">// Outbound · Trash</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-cream">
        Trash <span class="text-slate text-2xl font-normal">({total})</span>
      </h1>
      <p class="font-mono text-[11px] text-slate/60 mt-2">Deleted log entries — restore them, or delete forever.</p>
    </div>
    <a href="/admin/sent" class="font-mono text-[10px] tracking-widest uppercase px-3 py-2 border border-white/10 text-slate hover:text-electric hover:border-electric/40 transition-colors">← Back to Sent</a>
  </div>

  {emails.length === 0 ? (
    <div class="bg-navy border border-white/5 p-12 text-center">
      <p class="font-mono text-xs text-slate/60">Trash is empty.</p>
    </div>
  ) : (
    <ul class="flex flex-col gap-px bg-white/5">
      {emails.map((m) => (
        <li class="bg-navy p-5">
          <div class="flex items-start justify-between gap-4">
            <div class="flex flex-col gap-1 min-w-0">
              <div class="flex items-center gap-3 flex-wrap">
                {m.to_name && <span class="text-sm font-medium text-cream">{m.to_name}</span>}
                <span class="font-mono text-[11px] text-slate">{m.to_email}</span>
              </div>
              <p class="text-sm text-cream/80 font-medium mt-0.5">{m.subject}</p>
              <p class="font-mono text-[10px] text-slate/60 mt-0.5">sent {fmt(m.sent_at)} · {m.source} · {m.type}</p>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <button data-restore={m.id}
                class="font-mono text-[9px] tracking-widest uppercase px-2 py-1 border border-electric/40 text-electric hover:bg-electric hover:text-cream transition-colors">Restore</button>
              <button data-purge={m.id} data-to={m.to_email}
                class="font-mono text-[9px] tracking-widest uppercase px-2 py-1 border border-red-500/30 text-red-400/80 hover:text-red-400 hover:border-red-500/60 transition-colors">Delete forever</button>
            </div>
          </div>
        </li>
      ))}
    </ul>
  )}

  <script>
    document.querySelectorAll<HTMLButtonElement>('[data-restore]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.restore;
        if (!id) return;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/admin/sent/${id}?restore=true`, { method: 'POST' });
          if (!res.ok) throw new Error('Failed');
          btn.closest('li')?.remove();
        } catch { btn.disabled = false; alert('Restore failed — please retry.'); }
      });
    });
    document.querySelectorAll<HTMLButtonElement>('[data-purge]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.purge;
        const to = btn.dataset.to ?? 'this recipient';
        if (!id) return;
        if (!confirm(`Permanently delete the log entry for ${to}? This cannot be undone.`)) return;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/admin/sent/${id}?permanent=true`, { method: 'DELETE' });
          if (!res.ok) throw new Error('Failed');
          btn.closest('li')?.remove();
        } catch { btn.disabled = false; alert('Delete failed — please retry.'); }
      });
    });
  </script>

</AdminLayout>
