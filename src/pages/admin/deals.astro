---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

export const prerender = false;
const adminEmail = Astro.locals.adminEmail;

const STAGES = ['inquiry', 'discovery_scheduled', 'discovery_done', 'proposal_sent', 'negotiating', 'won', 'building', 'delivered', 'lost'];
const filter = Astro.url.searchParams.get('stage');

let q = supabaseAdmin.from('janet_deals').select('*').order('updated_at', { ascending: false });
if (filter && STAGES.includes(filter)) q = q.eq('stage', filter);
const { data: deals } = await q;
const { data: sites } = await supabaseAdmin.from('janet_sites').select('id, name').order('name');

const today = new Date().toISOString().slice(0, 10);
const daysSince = (iso: string) => Math.floor((Date.now() - new Date(iso).getTime()) / 86_400_000);
const stageColor = (s: string) =>
  s === 'won' || s === 'delivered' ? 'text-emerald-400 border-emerald-400/30'
  : s === 'lost' ? 'text-slate/50 border-white/10'
  : s === 'building' ? 'text-electric border-electric/30'
  : 'text-amber-400 border-amber-400/30';
---

<AdminLayout title="Deals" adminEmail={adminEmail} active="janet-deals">
  <div class="flex items-center justify-between mb-6">
    <div>
      <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-1">// JANET · Pipeline</p>
      <h1 class="text-2xl font-bold text-cream tracking-tight">Deals</h1>
    </div>
    <button id="new-deal" class="bg-electric hover:bg-electric/90 text-navy font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5 transition-colors">+ New deal</button>
  </div>

  <!-- Stage filter -->
  <div class="flex flex-wrap gap-1.5 mb-6">
    <a href="/admin/deals" class={`font-mono text-[9px] tracking-widest uppercase px-2.5 py-1.5 border transition-colors ${!filter ? 'bg-electric text-navy border-electric' : 'border-white/10 text-slate hover:text-cream'}`}>All</a>
    {STAGES.map((s) => (
      <a href={`/admin/deals?stage=${s}`} class={`font-mono text-[9px] tracking-widest uppercase px-2.5 py-1.5 border transition-colors ${filter === s ? 'bg-electric text-navy border-electric' : 'border-white/10 text-slate hover:text-cream'}`}>{s.replace(/_/g, ' ')}</a>
    ))}
  </div>

  <!-- List -->
  <div class="flex flex-col gap-2">
    {(deals ?? []).length === 0 && (
      <p class="text-slate/50 text-sm">No deals{filter ? ' in this stage' : ' yet'}. Add one, or tell JANET in the panel.</p>
    )}
    {(deals ?? []).map((d) => {
      const stale = daysSince(d.updated_at);
      const overdue = d.next_action_due && d.next_action_due < today && d.stage !== 'won' && d.stage !== 'lost' && d.stage !== 'delivered';
      return (
        <div class="border border-white/5 bg-navy p-4 hover:border-white/15 transition-colors" data-deal={JSON.stringify(d)}>
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-cream text-[15px] font-medium">{d.name}</span>
                <span class={`font-mono text-[8px] tracking-widest uppercase px-1.5 py-0.5 border rounded ${stageColor(d.stage)}`}>{d.stage.replace(/_/g, ' ')}</span>
                {d.outcome && <span class="font-mono text-[8px] tracking-widest uppercase text-slate/50">{d.outcome}</span>}
              </div>
              <p class="font-mono text-[11px] text-slate/60 mt-1">
                {d.contact_name ?? '—'}{d.contact_email ? ` · ${d.contact_email}` : ''}{d.source ? ` · ${d.source}` : ''}{d.value_estimate ? ` · $${Number(d.value_estimate).toLocaleString()}` : ''}
              </p>
              {d.next_action && (
                <p class={`font-mono text-[11px] mt-1.5 ${overdue ? 'text-red-400' : 'text-slate/70'}`}>
                  → {d.next_action}{d.next_action_due ? ` (${d.next_action_due}${overdue ? ' · overdue' : ''})` : ''}
                </p>
              )}
              {d.notes && <p class="text-slate/60 text-[12px] mt-1.5 leading-snug line-clamp-2">{d.notes}</p>}
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <span class="font-mono text-[9px] text-slate/40">{stale}d</span>
              <button class="edit-deal font-mono text-[9px] tracking-widest uppercase text-slate hover:text-electric transition-colors">Edit</button>
              <button class="del-deal font-mono text-[9px] tracking-widest uppercase text-slate hover:text-red-400 transition-colors" data-id={d.id}>Del</button>
            </div>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Add/Edit modal -->
  <div id="modal" class="hidden fixed inset-0 z-50 bg-black/60 backdrop-blur-sm grid place-items-center p-4">
    <div class="w-full max-w-lg bg-navy border border-white/10 shadow-2xl shadow-black/60 max-h-[90vh] overflow-y-auto">
      <div class="flex items-center justify-between px-5 h-12 border-b border-white/10">
        <span id="modal-title" class="font-mono text-[11px] tracking-[0.25em] uppercase text-cream">New deal</span>
        <button id="modal-close" class="text-slate hover:text-cream font-mono text-xs">✕</button>
      </div>
      <form id="deal-form" class="p-5 flex flex-col gap-3">
        <input type="hidden" name="id" />
        <div class="grid grid-cols-2 gap-3">
          <label class="col-span-2 flex flex-col gap-1"><span class="lbl">Name *</span><input name="name" required class="fld" /></label>
          <label class="flex flex-col gap-1"><span class="lbl">Contact name</span><input name="contact_name" class="fld" /></label>
          <label class="flex flex-col gap-1"><span class="lbl">Contact email</span><input name="contact_email" type="email" class="fld" /></label>
          <label class="flex flex-col gap-1"><span class="lbl">Stage</span>
            <select name="stage" class="fld">{STAGES.map((s) => <option value={s}>{s.replace(/_/g, ' ')}</option>)}</select>
          </label>
          <label class="flex flex-col gap-1"><span class="lbl">Source</span>
            <select name="source" class="fld"><option value="">—</option><option>referral</option><option>inbound</option><option>outbound</option><option>network</option></select>
          </label>
          <label class="flex flex-col gap-1"><span class="lbl">Value ($)</span><input name="value_estimate" type="number" class="fld" /></label>
          <label class="flex flex-col gap-1"><span class="lbl">Referred by</span><input name="referred_by" class="fld" /></label>
          <label class="flex flex-col gap-1"><span class="lbl">Next action</span><input name="next_action" class="fld" /></label>
          <label class="flex flex-col gap-1"><span class="lbl">Due</span><input name="next_action_due" type="date" class="fld" /></label>
          <label class="col-span-2 flex flex-col gap-1"><span class="lbl">Linked site</span>
            <select name="site_id" class="fld"><option value="">—</option>{(sites ?? []).map((s) => <option value={s.id}>{s.name}</option>)}</select>
          </label>
          <label class="col-span-2 flex flex-col gap-1"><span class="lbl">Notes</span><textarea name="notes" rows="3" class="fld resize-none"></textarea></label>
        </div>
        <div class="flex items-center justify-end gap-2 pt-1">
          <button type="button" id="modal-cancel" class="font-mono text-[10px] tracking-widest uppercase text-slate hover:text-cream px-3 py-2">Cancel</button>
          <button type="submit" class="bg-electric hover:bg-electric/90 text-navy font-mono text-[10px] tracking-widest uppercase px-4 py-2 transition-colors">Save</button>
        </div>
        <p id="form-err" class="font-mono text-[10px] text-red-400 hidden"></p>
      </form>
    </div>
  </div>
</AdminLayout>

<style>
  .lbl { font-family: monospace; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: #64748B; }
  .fld { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 0.5rem 0.6rem; color: #FAF8F3; font-size: 13px; }
  .fld:focus { outline: none; border-color: rgba(37,99,235,0.5); }
  select.fld option { background: #0A1628; }
</style>

<script>
  const modal = document.getElementById('modal')!;
  const form = document.getElementById('deal-form') as HTMLFormElement;
  const title = document.getElementById('modal-title')!;
  const err = document.getElementById('form-err')!;
  const open = (deal?: any) => {
    form.reset();
    err.classList.add('hidden');
    title.textContent = deal ? 'Edit deal' : 'New deal';
    (form.elements.namedItem('id') as HTMLInputElement).value = deal?.id ?? '';
    if (deal) for (const [k, v] of Object.entries(deal)) {
      const el = form.elements.namedItem(k) as HTMLInputElement | null;
      if (el && v != null) el.value = String(v);
    }
    modal.classList.remove('hidden');
  };
  const close = () => modal.classList.add('hidden');
  document.getElementById('new-deal')!.addEventListener('click', () => open());
  document.getElementById('modal-close')!.addEventListener('click', close);
  document.getElementById('modal-cancel')!.addEventListener('click', close);
  modal.addEventListener('click', (e) => { if (e.target === modal) close(); });

  document.querySelectorAll('.edit-deal').forEach((b) =>
    b.addEventListener('click', () => open(JSON.parse((b.closest('[data-deal]') as HTMLElement).dataset.deal!)))
  );
  document.querySelectorAll('.del-deal').forEach((b) =>
    b.addEventListener('click', async () => {
      if (!confirm('Delete this deal?')) return;
      await fetch(`/api/admin/janet/deals/${(b as HTMLElement).dataset.id}`, { method: 'DELETE' });
      location.reload();
    })
  );

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = Object.fromEntries(new FormData(form).entries());
    const id = fd.id;
    delete (fd as any).id;
    const res = await fetch(id ? `/api/admin/janet/deals/${id}` : '/api/admin/janet/deals', {
      method: id ? 'PUT' : 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(fd),
    });
    if (res.ok) location.reload();
    else { const d = await res.json().catch(() => ({})); err.textContent = d.error ?? 'Save failed'; err.classList.remove('hidden'); }
  });
</script>
