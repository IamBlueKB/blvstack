---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabase';
import { requireActor, requireRole } from '../../../../lib/booker/access';

export const prerender = false;

const adminEmail = Astro.locals.adminEmail;
const actor = requireActor(Astro.locals);
const denied = requireRole(actor, 'owner');
if (denied) return Astro.redirect('/admin/booker');

const verticalFilter = Astro.url.searchParams.get('vertical') ?? 'all';
const typeFilter = Astro.url.searchParams.get('type') ?? 'all';
const activeFilter = Astro.url.searchParams.get('active') ?? 'all';

let query = supabaseAdmin
  .from('booker_sources')
  .select('*')
  .order('vertical')
  .order('source_type')
  .order('city');

if (verticalFilter !== 'all') query = query.eq('vertical', verticalFilter);
if (typeFilter !== 'all') query = query.eq('source_type', typeFilter);
if (activeFilter !== 'all') query = query.eq('active', activeFilter === 'yes');

const { data: sources = [] } = await query;

const verticals = ['all', 'dj', 'rapper', 'singer', 'band', 'musician', 'poet', 'visual_artist', 'any'];
const sourceTypes = ['all', 'craigslist', 'eventbrite', 'patch', 'calendar', 'other'];
const activeFilters = [
  { key: 'all', label: 'All' },
  { key: 'yes', label: 'Active' },
  { key: 'no', label: 'Inactive' },
];

// Aggregate counts
const byType: Record<string, number> = {};
const byVertical: Record<string, number> = {};
for (const s of sources ?? []) {
  byType[s.source_type] = (byType[s.source_type] ?? 0) + 1;
  byVertical[s.vertical] = (byVertical[s.vertical] ?? 0) + 1;
}
---

<AdminLayout title="Sources" adminEmail={adminEmail} active="booker">

  <div class="flex items-center gap-3 mb-2">
    <a href="/admin/booker" class="font-mono text-[10px] tracking-widest uppercase text-slate hover:text-electric">&larr; BLVBooker</a>
  </div>

  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-2">// BLVBooker / Sources</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-cream">
        Scrape sources <span class="text-slate text-2xl font-normal">({(sources ?? []).length})</span>
      </h1>
      <p class="text-sm text-slate/80 mt-2 max-w-2xl">
        URLs the scraper hits when you run a vertical scrape. Filter by active sources for the chosen vertical only.
      </p>
    </div>
    <button id="btn-add" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5">+ Add source</button>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap gap-2 mb-3">
    <span class="font-mono text-[10px] tracking-widest uppercase text-slate/60 self-center">Vertical:</span>
    {verticals.map((v) => (
      <a href={`?vertical=${v}&type=${typeFilter}&active=${activeFilter}`} class={`font-mono text-[10px] tracking-widest uppercase px-3 py-1.5 border ${verticalFilter === v ? 'bg-electric border-electric text-cream' : 'border-white/10 text-slate hover:text-electric hover:border-electric/40'}`}>{v}</a>
    ))}
  </div>
  <div class="flex flex-wrap gap-2 mb-3">
    <span class="font-mono text-[10px] tracking-widest uppercase text-slate/60 self-center">Type:</span>
    {sourceTypes.map((t) => (
      <a href={`?vertical=${verticalFilter}&type=${t}&active=${activeFilter}`} class={`font-mono text-[10px] tracking-widest uppercase px-3 py-1.5 border ${typeFilter === t ? 'bg-electric border-electric text-cream' : 'border-white/10 text-slate hover:text-electric hover:border-electric/40'}`}>{t}</a>
    ))}
  </div>
  <div class="flex flex-wrap gap-2 mb-8">
    <span class="font-mono text-[10px] tracking-widest uppercase text-slate/60 self-center">Status:</span>
    {activeFilters.map((a) => (
      <a href={`?vertical=${verticalFilter}&type=${typeFilter}&active=${a.key}`} class={`font-mono text-[10px] tracking-widest uppercase px-3 py-1.5 border ${activeFilter === a.key ? 'bg-electric border-electric text-cream' : 'border-white/10 text-slate hover:text-electric hover:border-electric/40'}`}>{a.label}</a>
    ))}
  </div>

  <!-- Add Modal -->
  <div id="modal-add" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70">
    <div class="bg-navy border border-white/10 w-full max-w-xl mx-4 p-6">
      <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Add Source</p>
      <form id="add-form" class="flex flex-col gap-3">
        <input name="label" placeholder="Label (e.g., 'Craigslist Boston — Event gigs')" required class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
        <input name="url" type="url" placeholder="https://…" required class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60 font-mono" />
        <div class="flex gap-3">
          <select name="vertical" required class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60">
            <option value="">Vertical…</option>
            <option value="dj">DJ</option>
            <option value="rapper">Rapper</option>
            <option value="singer">Singer</option>
            <option value="band">Band</option>
            <option value="musician">Musician</option>
            <option value="poet">Poet</option>
            <option value="visual_artist">Visual artist</option>
            <option value="any">Any</option>
          </select>
          <select name="source_type" required class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60">
            <option value="">Type…</option>
            <option value="craigslist">Craigslist</option>
            <option value="eventbrite">Eventbrite</option>
            <option value="patch">Patch</option>
            <option value="calendar">Calendar</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="flex gap-3">
          <input name="city" placeholder="City (optional)" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          <input name="region" maxlength="2" placeholder="ST" class="w-20 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
        </div>
        <textarea name="notes" rows="2" placeholder="Notes (optional)" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60 resize-none"></textarea>
        <div class="flex items-center gap-3 mt-2">
          <button type="submit" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5">Add</button>
          <button type="button" id="btn-cancel" class="bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5">Cancel</button>
          <span id="add-status" class="font-mono text-[11px] text-slate/60 ml-auto"></span>
        </div>
      </form>
    </div>
  </div>

  {(sources ?? []).length === 0 ? (
    <div class="bg-navy border border-white/5 p-12 text-center">
      <p class="font-mono text-xs text-slate/60">No sources match this filter.</p>
    </div>
  ) : (
    <div class="overflow-x-auto border border-white/5">
      <table class="w-full text-sm">
        <thead class="bg-white/[0.03]">
          <tr>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-left px-4 py-3">Source</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-left px-4 py-3 hidden md:table-cell">Vertical</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-left px-4 py-3 hidden md:table-cell">Type</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-left px-4 py-3 hidden lg:table-cell">Last scraped</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-right px-4 py-3 hidden lg:table-cell">Last count</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-left px-4 py-3">Active</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-right px-4 py-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          {(sources ?? []).map((s: any) => (
            <tr class="border-t border-white/5 hover:bg-white/[0.03]" data-id={s.id}>
              <td class="px-4 py-3">
                <div class="text-cream font-medium">{s.label}</div>
                <div class="font-mono text-[11px] text-slate/60 break-all max-w-[420px]">{s.url}</div>
                {s.city && <div class="font-mono text-[10px] text-slate/40 mt-0.5">{s.city}, {s.region}</div>}
              </td>
              <td class="px-4 py-3 hidden md:table-cell text-slate font-mono text-[11px]">{s.vertical}</td>
              <td class="px-4 py-3 hidden md:table-cell text-slate font-mono text-[11px]">{s.source_type}</td>
              <td class="px-4 py-3 hidden lg:table-cell text-slate/60 font-mono text-[10px]">{s.last_scraped_at ? new Date(s.last_scraped_at).toLocaleDateString() : '—'}</td>
              <td class="px-4 py-3 hidden lg:table-cell text-right text-cream">{s.last_result_count ?? '—'}</td>
              <td class="px-4 py-3">
                {s.active
                  ? <span class="font-mono text-[10px] tracking-widest uppercase border px-2 py-1 text-emerald-400 border-emerald-400/40">YES</span>
                  : <span class="font-mono text-[10px] tracking-widest uppercase border px-2 py-1 text-slate/60 border-white/10">NO</span>}
              </td>
              <td class="px-4 py-3 text-right">
                <button data-toggle={s.id} data-active={s.active} class="font-mono text-[10px] tracking-widest uppercase text-electric hover:underline mr-3">{s.active ? 'Disable' : 'Enable'}</button>
                <button data-delete={s.id} class="font-mono text-[10px] tracking-widest uppercase text-red-400 hover:underline">Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

</AdminLayout>

<script>
  const modal = document.getElementById('modal-add');
  document.getElementById('btn-add')?.addEventListener('click', () => modal?.classList.remove('hidden'));
  document.getElementById('btn-cancel')?.addEventListener('click', () => modal?.classList.add('hidden'));
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });

  document.getElementById('add-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const body = {};
    fd.forEach((v, k) => { if (v) body[k] = v.toString(); });
    const status = document.getElementById('add-status');
    if (status) status.textContent = 'Adding…';
    const res = await fetch('/api/admin/booker/sources', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    if (res.ok) window.location.reload();
    else if (status) status.textContent = 'Failed';
  });

  document.querySelectorAll('[data-toggle]').forEach((btn: any) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-toggle');
      const currentlyActive = btn.getAttribute('data-active') === 'true';
      await fetch(`/api/admin/booker/sources/${id}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ active: !currentlyActive }),
      });
      window.location.reload();
    });
  });

  document.querySelectorAll('[data-delete]').forEach((btn: any) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-delete');
      if (!confirm('Delete this source permanently?')) return;
      await fetch(`/api/admin/booker/sources/${id}`, { method: 'DELETE' });
      window.location.reload();
    });
  });
</script>
