---
import AdminLayout from '../../../layouts/AdminLayout.astro';

export const prerender = false;
---

<AdminLayout title="BLVBooker Login" hideNav={true}>
  <div class="min-h-screen flex items-center justify-center px-6">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-2">// BLVBooker</p>
        <h1 class="text-3xl font-bold tracking-tight text-cream">Staff sign in</h1>
        <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mt-4">
          <a href="/admin/login" class="hover:text-electric transition-colors">Founder? Sign in here →</a>
        </p>
      </div>

      <form id="login-form" class="flex flex-col gap-4">
        <label class="flex flex-col gap-2">
          <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Email</span>
          <input type="email" name="email" required autocomplete="username" class="w-full bg-white/5 border border-white/10 px-3 py-2.5 text-sm text-cream focus:outline-none focus:border-electric/60 transition-colors" />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Password</span>
          <div class="relative pw-field">
            <input type="password" name="password" required autocomplete="current-password" class="w-full bg-white/5 border border-white/10 pl-3 pr-11 py-2.5 text-sm text-cream focus:outline-none focus:border-electric/60 transition-colors" />
            <button type="button" data-pw-toggle class="absolute right-2.5 top-1/2 -translate-y-1/2 text-slate hover:text-electric transition-colors p-1" aria-label="Show password">
              <svg data-eye-show width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" aria-hidden="true">
                <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
              <svg data-eye-hide width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="square" aria-hidden="true" class="hidden">
                <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-7 0-11-7-11-7a19.43 19.43 0 0 1 5.06-5.94M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 7 11 7a19.45 19.45 0 0 1-2.16 3.19M14.12 9.88A3 3 0 1 1 9.88 14.12" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
            </button>
          </div>
        </label>

        <button type="submit" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-3 transition-colors mt-2">
          Sign in
        </button>

        <p id="login-msg" class="font-mono text-[11px] tracking-wide text-red-400 hidden mt-2"></p>
      </form>
    </div>
  </div>

  <script>
    document.querySelectorAll<HTMLElement>('.pw-field').forEach((wrap) => {
      const input = wrap.querySelector<HTMLInputElement>('input');
      const btn = wrap.querySelector<HTMLButtonElement>('[data-pw-toggle]');
      const eyeShow = wrap.querySelector<SVGElement>('[data-eye-show]');
      const eyeHide = wrap.querySelector<SVGElement>('[data-eye-hide]');
      if (!input || !btn || !eyeShow || !eyeHide) return;
      btn.addEventListener('click', () => {
        const visible = input.type === 'text';
        input.type = visible ? 'password' : 'text';
        eyeShow.classList.toggle('hidden', !visible);
        eyeHide.classList.toggle('hidden', visible);
      });
    });

    const form = document.getElementById('login-form') as HTMLFormElement | null;
    const msg = document.getElementById('login-msg');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const body = { email: fd.get('email'), password: fd.get('password') };
      msg?.classList.add('hidden');
      try {
        const res = await fetch('/api/admin/booker/login', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
        });
        const json = await res.json();
        if (res.ok) {
          window.location.href = '/admin/booker';
        } else {
          if (msg) { msg.textContent = json.error ?? 'Sign in failed.'; msg.classList.remove('hidden'); }
        }
      } catch {
        if (msg) { msg.textContent = 'Network error.'; msg.classList.remove('hidden'); }
      }
    });
  </script>
</AdminLayout>
