---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabase';
import { requireActor, requireRole } from '../../../../lib/booker/access';

export const prerender = false;

const adminEmail = Astro.locals.adminEmail;
const actor = requireActor(Astro.locals);
const denied = requireRole(actor, 'owner');
if (denied) return Astro.redirect('/admin/booker');

const { data: staffList = [] } = await supabaseAdmin
  .from('booker_staff')
  .select('id, email, name, role, active, last_login_at, created_at')
  .is('deleted_at', null)
  .order('created_at', { ascending: false });

// Assignment counts
const ids = (staffList ?? []).map((s: any) => s.id);
const counts: Record<string, number> = {};
if (ids.length > 0) {
  const { data: assigns } = await supabaseAdmin
    .from('booker_staff_assignments')
    .select('staff_id')
    .in('staff_id', ids);
  for (const a of assigns ?? []) {
    counts[a.staff_id] = (counts[a.staff_id] ?? 0) + 1;
  }
}

function roleColor(r: string): string {
  switch (r) {
    case 'owner': return 'text-electric border-electric/40';
    case 'manager': return 'text-amber-400 border-amber-400/40';
    case 'agent': return 'text-emerald-400 border-emerald-400/40';
    default: return 'text-slate/80 border-white/10';
  }
}
---

<AdminLayout title="Staff" adminEmail={adminEmail} active="booker">

  <div class="flex items-center gap-3 mb-2">
    <a href="/admin/booker" class="font-mono text-[10px] tracking-widest uppercase text-slate hover:text-electric">&larr; BLVBooker</a>
  </div>

  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-2">// BLVBooker / Staff</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-cream">
        Staff <span class="text-slate text-2xl font-normal">({(staffList ?? []).length})</span>
      </h1>
    </div>
    <button id="btn-add" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5">+ New staff</button>
  </div>

  <!-- Create Modal -->
  <div id="modal-add" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70">
    <div class="bg-navy border border-white/10 w-full max-w-lg mx-4 p-6">
      <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// New Staff Member</p>
      <form id="add-form" class="flex flex-col gap-3">
        <input name="name" placeholder="Name" required class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
        <input type="email" name="email" placeholder="Email" required class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
        <select name="role" required class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60">
          <option value="">Role…</option>
          <option value="agent">Agent (scoped to assigned artists)</option>
          <option value="manager">Manager (full ops, no admin)</option>
          <option value="owner">Owner (full access)</option>
        </select>
        <input type="password" name="password" placeholder="Temp password (≥ 10 chars)" required minlength="10" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
        <div class="flex items-center gap-3 mt-2">
          <button type="submit" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5">Create</button>
          <button type="button" id="btn-cancel" class="bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5">Cancel</button>
          <span id="add-status" class="font-mono text-[11px] text-slate/60 ml-auto"></span>
        </div>
      </form>
    </div>
  </div>

  {(staffList ?? []).length === 0 ? (
    <div class="bg-navy border border-white/5 p-12 text-center">
      <p class="font-mono text-xs text-slate/60">No staff yet. The founder session always has owner access; add staff to delegate.</p>
    </div>
  ) : (
    <div class="overflow-x-auto border border-white/5">
      <table class="w-full text-sm">
        <thead class="bg-white/[0.03]">
          <tr>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-left px-4 py-3">Staff</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-left px-4 py-3">Role</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-right px-4 py-3 hidden md:table-cell">Assigned</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-left px-4 py-3 hidden md:table-cell">Active</th>
            <th class="font-mono text-[10px] tracking-widest uppercase text-slate/60 text-right px-4 py-3 hidden lg:table-cell">Last login</th>
          </tr>
        </thead>
        <tbody>
          {(staffList ?? []).map((s: any) => (
            <tr class="border-t border-white/5 hover:bg-white/[0.03]">
              <td class="px-4 py-3">
                <a href={`/admin/booker/staff/${s.id}`} class="text-cream hover:text-electric">
                  <div class="font-medium">{s.name ?? '—'}</div>
                  <div class="font-mono text-[11px] text-slate/60">{s.email}</div>
                </a>
              </td>
              <td class="px-4 py-3"><span class={`font-mono text-[10px] tracking-widest uppercase border px-2 py-1 ${roleColor(s.role)}`}>{s.role}</span></td>
              <td class="px-4 py-3 text-right text-slate hidden md:table-cell">{counts[s.id] ?? 0}</td>
              <td class="px-4 py-3 hidden md:table-cell">{s.active ? <span class="text-emerald-400 font-mono text-[10px]">YES</span> : <span class="text-red-400 font-mono text-[10px]">NO</span>}</td>
              <td class="px-4 py-3 text-right font-mono text-[11px] text-slate/60 hidden lg:table-cell">{s.last_login_at ? new Date(s.last_login_at).toLocaleDateString() : '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

</AdminLayout>

<script>
  const modal = document.getElementById('modal-add');
  document.getElementById('btn-add')?.addEventListener('click', () => modal?.classList.remove('hidden'));
  document.getElementById('btn-cancel')?.addEventListener('click', () => modal?.classList.add('hidden'));
  modal?.addEventListener('click', (e) => { if (e.target === modal) modal.classList.add('hidden'); });

  document.getElementById('add-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const body = { name: fd.get('name'), email: fd.get('email'), role: fd.get('role'), password: fd.get('password') };
    const status = document.getElementById('add-status');
    if (status) status.textContent = 'Creating…';
    const res = await fetch('/api/admin/booker/staff', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    const json = await res.json();
    if (res.ok && json.staff?.id) {
      window.location.href = `/admin/booker/staff/${json.staff.id}`;
    } else {
      if (status) status.textContent = json.error ?? 'Failed';
    }
  });
</script>
