---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabase';
import { requireActor, canAccessArtist, hasRole } from '../../../../lib/booker/access';

export const prerender = false;

const adminEmail = Astro.locals.adminEmail;
const actor = requireActor(Astro.locals);
const { id } = Astro.params;

if (!id || !(await canAccessArtist(actor, id))) {
  return Astro.redirect('/admin/booker/artists');
}

const seesMoney = hasRole(actor, 'manager');

const { data: artist } = await supabaseAdmin
  .from('booker_artists')
  .select('*')
  .eq('id', id)
  .single();

if (!artist) return Astro.redirect('/admin/booker/artists');

const { data: matches = [] } = await supabaseAdmin
  .from('booker_matches')
  .select('id, kind, score, status, created_at, gig:booker_gigs(title, venue_name), venue:booker_venues(name)')
  .eq('artist_id', id)
  .order('created_at', { ascending: false })
  .limit(20);

// Payments only for manager+
let payments: any[] = [];
if (seesMoney) {
  const { data } = await supabaseAdmin
    .from('booker_payments')
    .select('*')
    .eq('artist_id', id)
    .order('created_at', { ascending: false })
    .limit(10);
  payments = data ?? [];
}
---

<AdminLayout title={artist.stage_name ?? artist.name ?? 'Artist'} adminEmail={adminEmail} active="booker">

  <div class="flex items-center gap-3 mb-2">
    <a href="/admin/booker/artists" class="font-mono text-[10px] tracking-widest uppercase text-slate hover:text-electric">&larr; Roster</a>
  </div>

  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-2">// Artist</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-cream">{artist.stage_name ?? artist.name ?? 'Unnamed'}</h1>
      <p class="font-mono text-[11px] text-slate/60 mt-2">{artist.email ?? 'no email'}</p>
    </div>
    <span class="font-mono text-[10px] tracking-widest uppercase border px-3 py-1.5 text-slate/80 border-white/10">{artist.status}</span>
  </div>

  <div class="grid md:grid-cols-2 gap-6">

    <div class="flex flex-col gap-6">
      <div class="border border-white/5 bg-navy p-6">
        <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Profile</p>
        <form id="profile-form" class="flex flex-col gap-3">
          <div class="flex gap-3">
            <input name="stage_name" value={artist.stage_name ?? ''} placeholder="Stage name" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            <input name="name" value={artist.name ?? ''} placeholder="Legal name" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          </div>
          <div class="flex gap-3">
            <input type="email" name="email" value={artist.email ?? ''} placeholder="Email" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            <input name="phone" value={artist.phone ?? ''} placeholder="Phone" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          </div>
          <div class="flex gap-3">
            <select name="performer_type" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60">
              <option value="">type…</option>
              <option value="dj" selected={artist.performer_type === 'dj'}>DJ</option>
              <option value="musician" selected={artist.performer_type === 'musician'}>Musician</option>
              <option value="poet" selected={artist.performer_type === 'poet'}>Poet</option>
              <option value="visual_artist" selected={artist.performer_type === 'visual_artist'}>Visual artist</option>
              <option value="band" selected={artist.performer_type === 'band'}>Band</option>
              <option value="other" selected={artist.performer_type === 'other'}>Other</option>
            </select>
            <input name="city" value={artist.city ?? ''} placeholder="City" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            <input name="region" value={artist.region ?? ''} placeholder="ST" class="w-20 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          </div>
          <input name="genres" value={artist.genres ?? ''} placeholder="Genres" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          <textarea name="bio" placeholder="Bio" rows="3" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60 resize-none">{artist.bio ?? ''}</textarea>
          <button type="submit" class="w-fit bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">Save profile</button>
          <span id="profile-status" class="font-mono text-[11px] text-slate/60"></span>
        </form>
      </div>

      <div class="border border-white/5 bg-navy p-6">
        <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Intake</p>
        {artist.intake_completed_at ? (
          <p class="text-sm text-emerald-400">Completed {new Date(artist.intake_completed_at).toLocaleString()}</p>
        ) : (
          <p class="text-sm text-slate/80">
            {artist.intake_sent_at ? `Sent ${new Date(artist.intake_sent_at).toLocaleDateString()} · awaiting completion` : 'Not sent yet'}
          </p>
        )}
        <p class="font-mono text-[10px] text-slate/40 mt-2 break-all">{`/booker/intake/${artist.intake_token}`}</p>
        <div class="flex gap-3 mt-3">
          <button id="btn-send-intake" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">
            {artist.intake_sent_at ? 'Resend intake' : 'Send intake link'}
          </button>
          <button id="btn-copy-intake" class="bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">Copy link</button>
        </div>
        <span id="intake-status" class="font-mono text-[11px] text-slate/60 mt-2 block"></span>
      </div>
    </div>

    <div class="flex flex-col gap-6">

      {seesMoney && (
        <div class="border border-white/5 bg-navy p-6">
          <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Billing</p>
          <form id="billing-form" class="flex flex-col gap-3">
            <div class="flex gap-3 items-end">
              <label class="flex-1 flex flex-col gap-1">
                <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Monthly rate ($)</span>
                <input type="number" name="monthly_rate" value={artist.monthly_rate ?? ''} class="bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
              </label>
              <label class="flex-1 flex flex-col gap-1">
                <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Success fee %</span>
                <input type="number" step="0.1" name="success_fee_pct" value={artist.success_fee_pct ?? ''} class="bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
              </label>
            </div>
            <label class="flex flex-col gap-1">
              <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Status</span>
              <select name="status" class="bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60">
                <option value="prospect" selected={artist.status === 'prospect'}>prospect</option>
                <option value="onboarding" selected={artist.status === 'onboarding'}>onboarding</option>
                <option value="active" selected={artist.status === 'active'}>active</option>
                <option value="paused" selected={artist.status === 'paused'}>paused</option>
                <option value="churned" selected={artist.status === 'churned'}>churned</option>
              </select>
            </label>
            <button type="submit" class="w-fit bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">Save billing</button>
            <span id="billing-status" class="font-mono text-[11px] text-slate/60"></span>
          </form>
        </div>
      )}

      <div class="border border-white/5 bg-navy p-6">
        <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Recent Matches</p>
        {(matches ?? []).length === 0 ? (
          <p class="text-sm text-slate/60">No matches yet.</p>
        ) : (
          <div class="flex flex-col gap-2">
            {(matches ?? []).map((m: any) => (
              <a href={`/admin/booker/matches/${m.id}`} class="flex items-center justify-between bg-white/[0.03] border border-white/5 px-3 py-2 hover:border-electric/30">
                <div class="flex-1 min-w-0">
                  <p class="text-sm text-cream truncate">{m.kind === 'gig' ? `${m.gig?.title ?? 'gig'}` : `${m.venue?.name ?? 'venue'}`}</p>
                  <p class="font-mono text-[10px] text-slate/60">score {m.score} · {m.status.replace(/_/g, ' ')}</p>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>

      {seesMoney && (
        <div class="border border-white/5 bg-navy p-6">
          <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Recent Payments</p>
          {payments.length === 0 ? (
            <p class="text-sm text-slate/60">No payments tracked.</p>
          ) : (
            <div class="flex flex-col gap-2">
              {payments.map((p: any) => (
                <div class="flex items-center justify-between bg-white/[0.03] border border-white/5 px-3 py-2">
                  <div>
                    <p class="text-sm text-cream">{p.type} · ${p.amount}</p>
                    <p class="font-mono text-[10px] text-slate/60">{p.period ?? new Date(p.created_at).toLocaleDateString()}</p>
                  </div>
                  <span class={`font-mono text-[10px] uppercase ${p.status === 'paid' ? 'text-emerald-400' : p.status === 'overdue' ? 'text-red-400' : 'text-amber-400'}`}>{p.status}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

    </div>
  </div>

</AdminLayout>

<script define:vars={{ artistId: artist.id, intakeToken: artist.intake_token, seesMoney }}>
  const aid = artistId;

  document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const body = {};
    fd.forEach((v, k) => { body[k] = v; });
    const status = document.getElementById('profile-status');
    if (status) status.textContent = 'Saving…';
    const res = await fetch(`/api/admin/booker/artists/${aid}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    if (status) status.textContent = res.ok ? 'Saved.' : 'Failed.';
  });

  if (seesMoney) {
    document.getElementById('billing-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const body = {
        monthly_rate: parseInt(fd.get('monthly_rate'), 10) || null,
        success_fee_pct: parseFloat(fd.get('success_fee_pct')) || null,
        status: fd.get('status'),
      };
      const status = document.getElementById('billing-status');
      if (status) status.textContent = 'Saving…';
      const res = await fetch(`/api/admin/booker/artists/${aid}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      if (status) status.textContent = res.ok ? 'Saved.' : 'Failed.';
    });
  }

  document.getElementById('btn-send-intake')?.addEventListener('click', async function() {
    const status = document.getElementById('intake-status');
    if (status) status.textContent = 'Sending…';
    this.disabled = true;
    try {
      const res = await fetch(`/api/admin/booker/artists/${aid}/send-intake`, { method: 'POST' });
      const json = await res.json();
      if (res.ok) {
        if (status) status.textContent = 'Sent.';
        setTimeout(() => window.location.reload(), 1200);
      } else {
        if (status) status.textContent = json.error ?? 'Send failed.';
      }
    } catch {
      if (status) status.textContent = 'Network error';
    } finally {
      this.disabled = false;
    }
  });

  document.getElementById('btn-copy-intake')?.addEventListener('click', async function() {
    const status = document.getElementById('intake-status');
    const url = `${window.location.origin}/booker/intake/${intakeToken}`;
    try {
      await navigator.clipboard.writeText(url);
      if (status) status.textContent = 'Link copied.';
    } catch {
      if (status) status.textContent = url;
    }
  });
</script>
