---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabase';
import { requireActor, canAccessArtist, hasRole } from '../../../../lib/booker/access';

export const prerender = false;

const adminEmail = Astro.locals.adminEmail;
const actor = requireActor(Astro.locals);
const { id } = Astro.params;

if (!id || !(await canAccessArtist(actor, id))) {
  return Astro.redirect('/admin/booker/artists');
}

const seesMoney = hasRole(actor, 'manager');

const { data: artist } = await supabaseAdmin
  .from('booker_artists')
  .select('*')
  .eq('id', id)
  .single();

if (!artist) return Astro.redirect('/admin/booker/artists');

const { data: matches = [] } = await supabaseAdmin
  .from('booker_matches')
  .select('id, kind, score, status, created_at, gig:booker_gigs(title, venue_name), venue:booker_venues(name)')
  .eq('artist_id', id)
  .order('created_at', { ascending: false })
  .limit(20);

// Payments only for manager+
let payments: any[] = [];
if (seesMoney) {
  const { data } = await supabaseAdmin
    .from('booker_payments')
    .select('*')
    .eq('artist_id', id)
    .order('created_at', { ascending: false })
    .limit(10);
  payments = data ?? [];
}
---

<AdminLayout title={artist.stage_name ?? artist.name ?? 'Artist'} adminEmail={adminEmail} active="booker">

  <div class="flex items-center gap-3 mb-2">
    <a href="/admin/booker/artists" class="font-mono text-[10px] tracking-widest uppercase text-slate hover:text-electric">&larr; Roster</a>
  </div>

  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-2">// Artist</p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-cream">{artist.stage_name ?? artist.name ?? 'Unnamed'}</h1>
      <p class="font-mono text-[11px] text-slate/60 mt-2">{artist.email ?? 'no email'}</p>
    </div>
    <div class="flex items-center gap-2">
      <span class="font-mono text-[10px] tracking-widest uppercase text-slate/60">Status</span>
      <select id="status-quick" class="bg-white/5 border border-white/10 px-3 py-1.5 text-xs uppercase font-mono tracking-widest text-cream focus:outline-none focus:border-electric/60" style="color-scheme: dark;">
        <option value="prospect"   selected={artist.status === 'prospect'}   class="bg-navy text-cream">prospect</option>
        <option value="onboarding" selected={artist.status === 'onboarding'} class="bg-navy text-cream">onboarding</option>
        <option value="active"     selected={artist.status === 'active'}     class="bg-navy text-cream">active</option>
        <option value="paused"     selected={artist.status === 'paused'}     class="bg-navy text-cream">paused</option>
        <option value="churned"    selected={artist.status === 'churned'}    class="bg-navy text-cream">churned</option>
      </select>
      <span id="status-msg" class="font-mono text-[10px] text-slate/60"></span>
    </div>
  </div>

  <!-- Per-artist: find gigs -->
  <div class="border border-electric/20 bg-navy p-4 mb-3 flex items-center justify-between gap-3">
    <div>
      <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-1">// Find gigs for this artist</p>
      <p class="text-sm text-slate/80">Scrapes sources tagged for their performer types + runs the matcher just for them.</p>
    </div>
    <div class="flex items-center gap-3 shrink-0">
      <label class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Per type</label>
      <input id="find-max" type="number" value="10" min="1" max="100" class="w-20 bg-white/5 border border-white/10 px-2 py-1.5 text-sm text-cream focus:outline-none focus:border-electric/60" />
      <button id="btn-find-gigs" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5 transition-colors">⌕ Find gigs</button>
    </div>
  </div>
  <p id="find-status" class="font-mono text-[11px] text-slate/60 mb-6"></p>

  {seesMoney && (
    <>
      <!-- Per-artist: find venues -->
      <div class="border border-electric/20 bg-navy p-4 mb-3 flex items-center justify-between gap-3">
        <div>
          <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-1">// Find venues for this artist</p>
          <p class="text-sm text-slate/80">
            Google Places search across their verticals + city, then researches each new venue and matches it just for them.
            {!artist.city && <span class="text-amber-400 font-mono text-[11px]"> Requires city on profile.</span>}
          </p>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <label class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Venues to find</label>
          <input id="venues-max" type="number" value="10" min="1" max="40" class="w-20 bg-white/5 border border-white/10 px-2 py-1.5 text-sm text-cream focus:outline-none focus:border-electric/60" />
          <button id="btn-find-venues" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-4 py-2.5 transition-colors" disabled={!artist.city}>
            ⌕ Find venues
          </button>
        </div>
      </div>
      <p id="venues-status" class="font-mono text-[11px] text-slate/60 mb-6"></p>
    </>
  )}

  <div class="grid md:grid-cols-2 gap-6">

    <div class="flex flex-col gap-6">
      <div class="border border-white/5 bg-navy p-6">
        <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Profile</p>
        <form id="profile-form" class="flex flex-col gap-3">
          <div class="flex gap-3">
            <input name="stage_name" value={artist.stage_name ?? ''} placeholder="Stage name" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            <input name="name" value={artist.name ?? ''} placeholder="Legal name" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          </div>
          <div class="flex gap-3">
            <input type="email" name="email" value={artist.email ?? ''} placeholder="Email" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            <input id="phone-input" name="phone" type="tel" inputmode="numeric" maxlength="12" value={(() => { const d = (artist.phone ?? '').replace(/\D/g, '').slice(0, 10); if (d.length < 4) return d; if (d.length < 7) return `${d.slice(0,3)}-${d.slice(3)}`; return `${d.slice(0,3)}-${d.slice(3,6)}-${d.slice(6)}`; })()} placeholder="555-123-4567" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Performer types (one or more)</span>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
              {['dj','rapper','singer','band','musician','poet','visual_artist','other'].map((v) => {
                const checked = (artist.performer_types?.includes(v))
                  || (!artist.performer_types?.length && artist.performer_type === v);
                return (
                  <label class="flex items-center gap-2 bg-white/5 border border-white/10 px-2 py-1.5 cursor-pointer hover:border-electric/40">
                    <input type="checkbox" name="performer_types" value={v} checked={checked} />
                    <span class="font-mono text-[11px] text-cream uppercase tracking-wider">{v.replace(/_/g, ' ')}</span>
                  </label>
                );
              })}
            </div>
          </div>
          <label class="flex flex-col gap-1">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Location</span>
            <div class="flex gap-3">
              <input name="city" value={artist.city ?? ''} placeholder="City" class="flex-1 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
              <input name="region" value={artist.region ?? ''} placeholder="ST" class="w-20 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            </div>
          </label>
          <div class="flex gap-3">
            <label class="flex flex-col gap-1 w-44">
              <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Travel radius (mi)</span>
              <input type="number" name="travel_radius_mi" min="0" step="5" value={artist.travel_radius_mi ?? ''} placeholder="e.g. 100" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            </label>
            <label class="flex flex-col gap-1 flex-1">
              <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Availability notes</span>
              <input name="availability_notes" value={artist.availability_notes ?? ''} placeholder="e.g. weekends only, no Sunday mornings" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            </label>
          </div>
          <label class="flex flex-col gap-1">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Genres</span>
            <input name="genres" value={artist.genres ?? ''} placeholder="e.g. house, techno / spoken word / acoustic" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          </label>
          <div class="flex gap-3">
            <label class="flex flex-col gap-1 w-44">
              <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Rate floor (USD)</span>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate pointer-events-none text-sm">$</span>
                <input type="number" name="rate_floor" min="0" step="50" value={artist.rate_floor ?? ''} placeholder="500" class="w-full bg-white/5 border border-white/10 pl-7 pr-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
              </div>
            </label>
            <label class="flex flex-col gap-1 flex-1">
              <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Rate notes</span>
              <input name="rate_notes" value={artist.rate_notes ?? ''} placeholder="e.g. higher for weddings" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
            </label>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Gig types they want</span>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
              {['weddings','clubs','corporate','private','festivals','open_mics','college','restaurants'].map((g) => {
                const checked = (artist.gig_types as string[] | null)?.includes(g) ?? false;
                return (
                  <label class="flex items-center gap-2 bg-white/5 border border-white/10 px-2 py-1.5 cursor-pointer hover:border-electric/40">
                    <input type="checkbox" name="gig_types" value={g} checked={checked} />
                    <span class="font-mono text-[11px] text-cream uppercase tracking-wider">{g.replace(/_/g, ' ')}</span>
                  </label>
                );
              })}
            </div>
          </div>
          <label class="flex flex-col gap-1">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Bio</span>
            <textarea name="bio" rows="3" placeholder="Short bio" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60 resize-none">{artist.bio ?? ''}</textarea>
          </label>
          <label class="flex flex-col gap-1">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Hard nos</span>
            <textarea name="hard_nos" rows="2" placeholder="e.g. no kids' parties, no overnight drives, no requests for X genre…" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60 resize-none">{artist.hard_nos ?? ''}</textarea>
          </label>
          <button type="submit" class="w-fit bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">Save profile</button>
          <span id="profile-status" class="font-mono text-[11px] text-slate/60"></span>
        </form>
      </div>

      <!-- Press kit + demo + socials -->
      <div class="border border-white/5 bg-navy p-6">
        <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Links & Socials</p>

        {/* Quick-view: clickable list of every link this artist has */}
        {(() => {
          const sl = (artist.social_links as any) ?? {};
          const rows: { label: string; url: string }[] = [];
          if (artist.press_kit_url) rows.push({ label: 'Press kit', url: artist.press_kit_url });
          if (artist.demo_url) rows.push({ label: 'Demo', url: artist.demo_url });
          for (const [k, v] of Object.entries(sl)) {
            if (v) rows.push({ label: k.replace(/_/g, ' '), url: v as string });
          }
          if (rows.length === 0) {
            return <p class="text-sm text-slate/60 mb-5">No links yet.</p>;
          }
          return (
            <div class="bg-white/[0.03] border border-white/5 p-3 mb-5">
              <p class="font-mono text-[10px] tracking-widest uppercase text-slate/60 mb-2">All links</p>
              <ul class="flex flex-col gap-1.5">
                {rows.map((r) => (
                  <li class="flex items-baseline gap-3">
                    <span class="font-mono text-[10px] uppercase tracking-widest text-slate/60 w-24 shrink-0">{r.label}</span>
                    <a href={r.url} target="_blank" rel="noopener" class="text-sm text-electric hover:underline break-all">{r.url}</a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })()}

        <form id="links-form" class="flex flex-col gap-3">
          <label class="flex flex-col gap-1">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Press kit URL</span>
            <input name="press_kit_url" type="url" value={artist.press_kit_url ?? ''} placeholder="https://…" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          </label>
          <label class="flex flex-col gap-1">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Demo / sample URL</span>
            <input name="demo_url" type="url" value={artist.demo_url ?? ''} placeholder="SoundCloud, YouTube, Spotify…" class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
          </label>
          <div class="grid grid-cols-2 gap-3 mt-2">
            {[
              { key: 'instagram',  label: 'Instagram',  ph: '@handle or URL' },
              { key: 'tiktok',     label: 'TikTok',     ph: '@handle or URL' },
              { key: 'spotify',    label: 'Spotify',    ph: 'Artist URL' },
              { key: 'soundcloud', label: 'SoundCloud', ph: 'Profile URL' },
              { key: 'youtube',    label: 'YouTube',    ph: 'Channel URL' },
              { key: 'website',    label: 'Website',    ph: 'https://…' },
            ].map((s) => (
              <label class="flex flex-col gap-1">
                <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">{s.label}</span>
                <input name={`social_${s.key}`} value={(artist.social_links as any)?.[s.key] ?? ''} placeholder={s.ph} class="w-full bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
              </label>
            ))}
          </div>

          <!-- Custom extras (any platform: BandCamp, Patreon, Linktree, press features…) -->
          <div class="mt-2">
            <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Other links</span>
            <div class="flex flex-col gap-2 mt-2">
              {Array.from({ length: 5 }, (_, i) => {
                const namedKeys = ['instagram','tiktok','spotify','soundcloud','youtube','website'];
                const sl = (artist.social_links as any) ?? {};
                const extraKeys = Object.keys(sl).filter((k) => !namedKeys.includes(k));
                const ek = extraKeys[i];
                return (
                  <div class="grid grid-cols-3 gap-2">
                    <input name={`extra_label_${i}`} value={ek ?? ''} placeholder="Platform / label" class="bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
                    <input name={`extra_url_${i}`} value={ek ? (sl[ek] ?? '') : ''} placeholder="https://…" class="col-span-2 bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
                  </div>
                );
              })}
            </div>
          </div>

          <button type="submit" class="w-fit bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2 mt-3">Save links</button>
          <span id="links-status" class="font-mono text-[11px] text-slate/60"></span>
        </form>
      </div>

      <div class="border border-white/5 bg-navy p-6">
        <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Intake</p>
        {artist.intake_completed_at ? (
          <p class="text-sm text-emerald-400">Completed {new Date(artist.intake_completed_at).toLocaleString()}</p>
        ) : (
          <>
            <p class="text-sm text-slate/80">
              {artist.intake_sent_at ? `Sent ${new Date(artist.intake_sent_at).toLocaleDateString()} · awaiting completion` : 'Not sent yet'}
            </p>
            {artist.intake_expires_at && (
              new Date(artist.intake_expires_at).getTime() < Date.now() ? (
                <p class="text-sm text-red-400 mt-1">Link expired {new Date(artist.intake_expires_at).toLocaleDateString()} — resend to issue a new 14-day window.</p>
              ) : (
                <p class="text-sm text-amber-400 mt-1">Link expires {new Date(artist.intake_expires_at).toLocaleDateString()}</p>
              )
            )}
          </>
        )}
        <p class="font-mono text-[10px] text-slate/40 mt-2 break-all">{`/booker/intake/${artist.intake_token}`}</p>
        <div class="flex gap-3 mt-3">
          <button id="btn-send-intake" class="bg-electric hover:bg-electric/90 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">
            {artist.intake_sent_at ? 'Resend intake' : 'Send intake link'}
          </button>
          <button id="btn-copy-intake" class="bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">Copy link</button>
        </div>
        <span id="intake-status" class="font-mono text-[11px] text-slate/60 mt-2 block"></span>
      </div>
    </div>

    <div class="flex flex-col gap-6">

      {seesMoney && (
        <div class="border border-white/5 bg-navy p-6">
          <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Billing</p>
          <form id="billing-form" class="flex flex-col gap-3">
            <div class="flex gap-3 items-end">
              <label class="flex-1 flex flex-col gap-1">
                <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Monthly rate (USD)</span>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate pointer-events-none text-sm">$</span>
                  <input type="number" name="monthly_rate" min="0" step="1" value={artist.monthly_rate ?? ''} placeholder="0" class="w-full bg-white/5 border border-white/10 pl-7 pr-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
                </div>
              </label>
              <label class="flex-1 flex flex-col gap-1">
                <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Success fee %</span>
                <div class="relative">
                  <input type="number" step="0.1" min="0" max="100" name="success_fee_pct" value={artist.success_fee_pct ?? ''} placeholder="10.0" class="w-full bg-white/5 border border-white/10 pl-3 pr-7 py-2 text-sm text-cream focus:outline-none focus:border-electric/60" />
                  <span class="absolute right-3 top-1/2 -translate-y-1/2 text-slate pointer-events-none text-sm">%</span>
                </div>
              </label>
            </div>
            <label class="flex flex-col gap-1">
              <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Status</span>
              <select name="status" style="color-scheme: dark;" class="bg-white/5 border border-white/10 px-3 py-2 text-sm text-cream focus:outline-none focus:border-electric/60">
                <option value="prospect"   selected={artist.status === 'prospect'}   class="bg-navy text-cream">prospect</option>
                <option value="onboarding" selected={artist.status === 'onboarding'} class="bg-navy text-cream">onboarding</option>
                <option value="active"     selected={artist.status === 'active'}     class="bg-navy text-cream">active</option>
                <option value="paused"     selected={artist.status === 'paused'}     class="bg-navy text-cream">paused</option>
                <option value="churned"    selected={artist.status === 'churned'}    class="bg-navy text-cream">churned</option>
              </select>
            </label>
            <button type="submit" class="w-fit bg-white/5 hover:bg-white/10 border border-white/10 text-cream font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">Save billing</button>
            <span id="billing-status" class="font-mono text-[11px] text-slate/60"></span>
          </form>
        </div>
      )}

      <div class="border border-white/5 bg-navy p-6">
        <div class="flex items-center justify-between mb-4">
          <p class="font-mono text-[10px] tracking-widest uppercase text-electric">// Recent Matches</p>
          <a href={`/admin/booker/matches?artist=${artist.id}`} class="font-mono text-[10px] tracking-widest uppercase text-slate hover:text-electric">View all →</a>
        </div>
        {(matches ?? []).length === 0 ? (
          <p class="text-sm text-slate/60">No matches yet.</p>
        ) : (
          <div class="flex flex-col gap-2">
            {(matches ?? []).map((m: any) => (
              <a href={`/admin/booker/matches/${m.id}`} class="flex items-center justify-between bg-white/[0.03] border border-white/5 px-3 py-2 hover:border-electric/30">
                <div class="flex-1 min-w-0">
                  <p class="text-sm text-cream truncate">{m.kind === 'gig' ? `${m.gig?.title ?? 'gig'}` : `${m.venue?.name ?? 'venue'}`}</p>
                  <p class="font-mono text-[10px] text-slate/60">score {m.score} · {m.status.replace(/_/g, ' ')}</p>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>

      {seesMoney && (
        <div class="border border-white/5 bg-navy p-6">
          <p class="font-mono text-[10px] tracking-widest uppercase text-electric mb-4">// Recent Payments</p>
          {payments.length === 0 ? (
            <p class="text-sm text-slate/60">No payments tracked.</p>
          ) : (
            <div class="flex flex-col gap-2">
              {payments.map((p: any) => (
                <div class="flex items-center justify-between bg-white/[0.03] border border-white/5 px-3 py-2">
                  <div>
                    <p class="text-sm text-cream">{p.type} · ${p.amount}</p>
                    <p class="font-mono text-[10px] text-slate/60">{p.period ?? new Date(p.created_at).toLocaleDateString()}</p>
                  </div>
                  <span class={`font-mono text-[10px] uppercase ${p.status === 'paid' ? 'text-emerald-400' : p.status === 'overdue' ? 'text-red-400' : 'text-amber-400'}`}>{p.status}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      )}

    </div>
  </div>

  {seesMoney && (
    <div class="border border-red-500/20 bg-navy p-6 mt-6">
      <p class="font-mono text-[10px] tracking-widest uppercase text-red-400 mb-4">// Danger Zone</p>
      <div class="flex gap-3">
        <button id="btn-churn" class="bg-white/5 hover:bg-red-500/20 border border-white/10 text-slate hover:text-red-400 font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">Mark churned</button>
        <button id="btn-delete" class="bg-white/5 hover:bg-red-500/20 border border-white/10 text-slate hover:text-red-400 font-mono text-[10px] tracking-[0.25em] uppercase px-3 py-2">Soft delete</button>
      </div>
      <p class="font-mono text-[10px] text-slate/40 mt-3">Soft delete sets <code>deleted_at</code> — artist hides from all lists. Recover via SQL if needed.</p>
    </div>
  )}

</AdminLayout>

<script define:vars={{ artistId: artist.id, intakeToken: artist.intake_token, seesMoney }}>
  const aid = artistId;

  // Phone field — live-format as US ###-###-#### while typing
  (function() {
    const el = document.getElementById('phone-input');
    if (!el) return;
    const format = (s) => {
      const d = (s || '').replace(/\D/g, '').slice(0, 10);
      if (d.length < 4) return d;
      if (d.length < 7) return `${d.slice(0,3)}-${d.slice(3)}`;
      return `${d.slice(0,3)}-${d.slice(3,6)}-${d.slice(6)}`;
    };
    el.addEventListener('input', () => {
      const before = el.value;
      const after = format(before);
      if (before !== after) {
        const caret = el.selectionStart ?? after.length;
        el.value = after;
        // Best-effort caret restoration: place at end if it was at end
        if (caret >= before.length) el.setSelectionRange(after.length, after.length);
      }
    });
  })();

  // Per-artist find venues
  document.getElementById('btn-find-venues')?.addEventListener('click', async function() {
    const max = parseInt(document.getElementById('venues-max').value, 10) || 10;
    const status = document.getElementById('venues-status');
    if (status) status.textContent = `Searching Places (up to ${max} venues per query) + researching + matching…`;
    this.disabled = true;
    try {
      const res = await fetch(`/api/admin/booker/artists/${aid}/find-venues`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ maxVenuesPerQuery: max }),
      });
      // Server might return a Vercel HTML error page on timeout/crash — handle gracefully
      const contentType = res.headers.get('content-type') ?? '';
      let json;
      if (contentType.includes('application/json')) {
        json = await res.json();
      } else {
        const text = await res.text();
        const snippet = text.slice(0, 120).replace(/\s+/g, ' ').trim();
        throw new Error(res.status === 504 || /timeout|exceeded/i.test(text)
          ? `Function timed out — partial venues may have been saved. Click again to continue.`
          : `Server error (${res.status}): ${snippet}`);
      }
      if (res.ok) {
        if (status) {
          const parts = [
            `Searched ${json.radius_miles_used}mi`,
            `${json.candidates_seen} candidates`,
            `${json.skipped_duplicate} dupes`,
            `${json.skipped_no_website} no-website`,
            `${json.venues_inserted} NEW`,
            `${json.venues_researched} researched`,
            `${json.matches_created} matches`,
          ];
          if (json.unresearched_remaining > 0) {
            const reason = json.reached_research_cap ? 'cap' : json.reached_time_budget ? 'time' : 'queued';
            parts.push(`${json.unresearched_remaining} unresearched (${reason}) — click again to continue`);
          }
          status.textContent = parts.join(' · ');
        }
        if (json.matches_created > 0) setTimeout(() => window.location.reload(), 2400);
      } else {
        if (status) status.textContent = json.error ?? 'Find venues failed';
      }
    } catch (err) {
      if (status) status.textContent = `Network error${err?.message ? `: ${err.message}` : ''}`;
    } finally {
      this.disabled = !document.getElementById('btn-find-venues').hasAttribute('disabled');
    }
  });

  // Per-artist find gigs
  document.getElementById('btn-find-gigs')?.addEventListener('click', async function() {
    const max = parseInt(document.getElementById('find-max').value, 10) || 10;
    const status = document.getElementById('find-status');
    if (status) status.textContent = `Scraping per vertical (up to ${max} gigs each) + matching…`;
    this.disabled = true;
    try {
      const res = await fetch(`/api/admin/booker/artists/${aid}/find-gigs`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ maxGigsPerVertical: max }),
      });
      const contentType = res.headers.get('content-type') ?? '';
      let json;
      if (contentType.includes('application/json')) {
        json = await res.json();
      } else {
        const text = await res.text();
        throw new Error(res.status === 504 || /timeout|exceeded/i.test(text)
          ? `Function timed out — partial gigs may have been saved. Click again to continue.`
          : `Server error (${res.status}): ${text.slice(0, 120).replace(/\s+/g, ' ').trim()}`);
      }
      if (res.ok) {
        if (status) {
          status.textContent = `Inserted ${json.gigs_inserted} gigs · created ${json.matches_created} matches for this artist`;
        }
        if (json.matches_created > 0) setTimeout(() => window.location.reload(), 1800);
      } else {
        if (status) status.textContent = json.error ?? 'Find gigs failed';
      }
    } catch (err) {
      if (status) status.textContent = `Network error${err?.message ? `: ${err.message}` : ''}`;
    } finally {
      this.disabled = false;
    }
  });

  // Inline status changer at top of page — saves immediately on change
  document.getElementById('status-quick')?.addEventListener('change', async (e) => {
    const newStatus = e.target.value;
    const msg = document.getElementById('status-msg');
    if (msg) msg.textContent = 'Saving…';
    const res = await fetch(`/api/admin/booker/artists/${aid}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: newStatus }),
    });
    if (msg) msg.textContent = res.ok ? 'Saved.' : 'Failed.';
  });

  document.getElementById('profile-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const body = {};
    const performerTypes = [];
    const gigTypes = [];
    fd.forEach((v, k) => {
      if (k === 'performer_types') { performerTypes.push(v); return; }
      if (k === 'gig_types') { gigTypes.push(v); return; }
      const trimmed = (v ?? '').toString().trim();
      if (k === 'travel_radius_mi' || k === 'rate_floor') {
        body[k] = trimmed ? parseInt(trimmed, 10) : null;
        return;
      }
      // Empty strings → null so clearing a field actually clears it in DB
      body[k] = trimmed === '' ? null : trimmed;
    });
    body.performer_types = performerTypes; // Always send array (even if empty — clears the field)
    body.gig_types = gigTypes;              // same — clears if all unchecked
    const status = document.getElementById('profile-status');
    if (status) status.textContent = 'Saving…';
    const res = await fetch(`/api/admin/booker/artists/${aid}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    if (status) status.textContent = res.ok ? 'Saved.' : 'Failed.';
  });

  if (seesMoney) {
    document.getElementById('billing-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const body = {
        monthly_rate: parseInt(fd.get('monthly_rate'), 10) || null,
        success_fee_pct: parseFloat(fd.get('success_fee_pct')) || null,
        status: fd.get('status'),
      };
      const status = document.getElementById('billing-status');
      if (status) status.textContent = 'Saving…';
      const res = await fetch(`/api/admin/booker/artists/${aid}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      if (status) status.textContent = res.ok ? 'Saved.' : 'Failed.';
    });
  }

  document.getElementById('links-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const body = {
      press_kit_url: fd.get('press_kit_url') || null,
      demo_url: fd.get('demo_url') || null,
      social_links: {},
    };

    // Named socials
    for (const k of ['instagram','tiktok','spotify','soundcloud','youtube','website']) {
      const v = fd.get(`social_${k}`);
      if (v) body.social_links[k] = v;
    }

    // Custom extras — slugify the label as the key; auto-suffix on collision
    // so multiple "YouTube" extras become youtube_2, youtube_3 instead of being dropped.
    const slugify = (s) => s.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '').slice(0, 40) || 'link';
    const uniqueKey = (base, taken) => {
      if (!taken.has(base)) return base;
      let i = 2;
      while (taken.has(`${base}_${i}`)) i++;
      return `${base}_${i}`;
    };
    const taken = new Set(Object.keys(body.social_links));
    for (let i = 0; i < 5; i++) {
      const label = (fd.get(`extra_label_${i}`) || '').toString().trim();
      const url = (fd.get(`extra_url_${i}`) || '').toString().trim();
      if (label && url) {
        const key = uniqueKey(slugify(label), taken);
        body.social_links[key] = url;
        taken.add(key);
      }
    }

    if (Object.keys(body.social_links).length === 0) body.social_links = null;
    const status = document.getElementById('links-status');
    if (status) status.textContent = 'Saving…';
    const res = await fetch(`/api/admin/booker/artists/${aid}`, {
      method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
    });
    if (status) status.textContent = res.ok ? 'Saved.' : 'Failed.';
  });

  document.getElementById('btn-send-intake')?.addEventListener('click', async function() {
    const status = document.getElementById('intake-status');
    if (status) status.textContent = 'Sending…';
    this.disabled = true;
    try {
      const res = await fetch(`/api/admin/booker/artists/${aid}/send-intake`, { method: 'POST' });
      const json = await res.json();
      if (res.ok) {
        if (status) status.textContent = 'Sent.';
        setTimeout(() => window.location.reload(), 1200);
      } else {
        if (status) status.textContent = json.error ?? 'Send failed.';
      }
    } catch {
      if (status) status.textContent = 'Network error';
    } finally {
      this.disabled = false;
    }
  });

  document.getElementById('btn-copy-intake')?.addEventListener('click', async function() {
    const status = document.getElementById('intake-status');
    const url = `${window.location.origin}/booker/intake/${intakeToken}`;
    try {
      await navigator.clipboard.writeText(url);
      if (status) status.textContent = 'Link copied.';
    } catch {
      if (status) status.textContent = url;
    }
  });

  if (seesMoney) {
    document.getElementById('btn-churn')?.addEventListener('click', async () => {
      if (!confirm('Mark this artist as churned?')) return;
      await fetch(`/api/admin/booker/artists/${aid}`, {
        method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: 'churned' }),
      });
      window.location.reload();
    });

    document.getElementById('btn-delete')?.addEventListener('click', async () => {
      if (!confirm('Soft delete this artist? They\'ll disappear from all lists. Recover via SQL if needed.')) return;
      const res = await fetch(`/api/admin/booker/artists/${aid}`, { method: 'DELETE' });
      if (res.ok) window.location.href = '/admin/booker/artists';
    });
  }
</script>
