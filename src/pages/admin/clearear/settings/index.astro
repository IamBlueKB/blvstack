---
// Clear Ear Studios — settings: issuer details (appear on every invoice) and the
// payment-method instructions clients pay by. Blue fills these; nothing invented.
// (Phase 2.)
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../../../lib/supabase';

export const prerender = false;
const adminEmail = Astro.locals.adminEmail;

const [{ data: s }, { data: methods }] = await Promise.all([
  supabaseAdmin.from('clearear_settings').select('*').eq('id', 1).maybeSingle(),
  supabaseAdmin.from('clearear_payment_methods').select('*').order('sort_order'),
]);
const settings = s ?? {};
const addr = (settings.address && typeof settings.address === 'object' ? settings.address : {}) as any;
const rows = (methods ?? []) as any[];
---

<AdminLayout title="Clear Ear Settings" adminEmail={adminEmail} active="clearear-settings">
  <div class="mb-6">
    <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-2">// Clear Ear · Settings</p>
    <h1 class="text-3xl font-bold tracking-tight text-cream">Settings</h1>
    <p class="font-mono text-[11px] text-slate/60 mt-2">Issuer details print on every invoice; payment instructions tell clients how to pay.</p>
  </div>

  <div class="grid lg:grid-cols-2 gap-4 max-w-5xl">
    <!-- Issuer -->
    <div class="bg-navy border border-white/5 p-5">
      <p class="font-mono text-[9px] uppercase tracking-widest text-slate/40 mb-4">Business / issuer</p>
      <div class="space-y-2" id="issuer">
        <input data-k="business_name" value={settings.business_name ?? ''} placeholder="Business name" class="w-full bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
        <div class="grid grid-cols-2 gap-2">
          <input data-k="email" value={settings.email ?? ''} placeholder="Email" class="bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
          <input data-k="phone" value={settings.phone ?? ''} placeholder="Phone" class="bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
        </div>
        <input data-a="line1" value={addr.line1 ?? ''} placeholder="Address line 1" class="w-full bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
        <input data-a="line2" value={addr.line2 ?? ''} placeholder="Address line 2" class="w-full bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
        <div class="grid grid-cols-3 gap-2">
          <input data-a="city" value={addr.city ?? ''} placeholder="City" class="bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
          <input data-a="state" value={addr.state ?? ''} placeholder="State" class="bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
          <input data-a="zip" value={addr.zip ?? ''} placeholder="ZIP" class="bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
        </div>
        <div class="grid grid-cols-2 gap-2">
          <input data-k="tax_id" value={settings.tax_id ?? ''} placeholder="EIN / Tax ID" class="bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
          <input data-k="default_tax_rate" value={settings.default_tax_rate ?? 0} placeholder="Default tax %" inputmode="decimal" class="bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
        </div>
        <input data-k="default_terms" value={settings.default_terms ?? ''} placeholder="Default terms (e.g. Net 15)" class="w-full bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" />
        <textarea data-k="default_notes" rows="2" placeholder="Default invoice notes" class="w-full bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/85">{settings.default_notes ?? ''}</textarea>
      </div>
      <div class="mt-3 flex items-center gap-3">
        <button id="save-issuer" class="font-mono text-[10px] uppercase tracking-widest px-4 py-2 border border-emerald-500/40 text-emerald-400 hover:bg-emerald-500/10">Save issuer</button>
        <span id="issuer-msg" class="font-mono text-[10px] text-slate/50"></span>
      </div>
    </div>

    <!-- Payment methods -->
    <div class="bg-navy border border-white/5 p-5">
      <p class="font-mono text-[9px] uppercase tracking-widest text-slate/40 mb-4">Payment methods & instructions</p>
      <ul class="flex flex-col gap-3" id="methods">
        {rows.map((m) => (
          <li data-id={m.id} class="border border-white/5 p-3">
            <div class="flex items-center justify-between mb-2">
              <span class="font-mono text-[12px] text-cream/90">{m.label}</span>
              <button class="m-active font-mono text-[9px] uppercase tracking-widest px-2 py-1 border" data-active={String(m.active)}>{m.active ? 'active' : 'inactive'}</button>
            </div>
            <input class="m-instr w-full bg-white/[0.03] border border-white/10 px-3 py-2 text-[13px] text-cream/90" value={m.instructions ?? ''} placeholder={`How clients pay by ${m.label} (e.g. $handle, email, "check payable to…")`} />
            <div class="flex items-center gap-2 mt-2">
              <button class="m-save font-mono text-[9px] uppercase tracking-widest px-3 py-1 border border-white/10 text-slate hover:text-electric">Save</button>
              <span class="m-msg font-mono text-[9px] text-slate/50"></span>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  (function () {
    async function post(body) {
      var res = await fetch('/api/admin/clearear/settings', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      return { ok: res.ok, json: await res.json().catch(function () { return {}; }) };
    }
    document.getElementById('save-issuer').addEventListener('click', async function () {
      var msg = document.getElementById('issuer-msg'); msg.textContent = '…';
      var body = { section: 'issuer', address: {} };
      document.querySelectorAll('#issuer [data-k]').forEach(function (el) { body[el.getAttribute('data-k')] = el.value; });
      document.querySelectorAll('#issuer [data-a]').forEach(function (el) { body.address[el.getAttribute('data-a')] = el.value; });
      var r = await post(body);
      msg.textContent = r.ok ? '✓ saved' : (r.json.error || 'error');
    });
    document.querySelectorAll('#methods li').forEach(function (li) {
      var activeBtn = li.querySelector('.m-active');
      var msg = li.querySelector('.m-msg');
      function paint() { var on = activeBtn.getAttribute('data-active') === 'true'; activeBtn.textContent = on ? 'active' : 'inactive'; activeBtn.className = 'm-active font-mono text-[9px] uppercase tracking-widest px-2 py-1 border ' + (on ? 'border-emerald-500/40 text-emerald-400' : 'border-white/10 text-slate/50'); }
      paint();
      activeBtn.addEventListener('click', function () { activeBtn.setAttribute('data-active', activeBtn.getAttribute('data-active') === 'true' ? 'false' : 'true'); paint(); });
      li.querySelector('.m-save').addEventListener('click', async function () {
        msg.textContent = '…';
        var r = await post({ section: 'method', id: li.getAttribute('data-id'), instructions: li.querySelector('.m-instr').value, active: activeBtn.getAttribute('data-active') === 'true' });
        msg.textContent = r.ok ? '✓ saved' : (r.json.error || 'error');
      });
    });
  })();
</script>
