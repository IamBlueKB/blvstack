---
import AdminLayout from '../../layouts/AdminLayout.astro';

export const prerender = false;

const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="Sign in" hideNav={true}>
  <section class="min-h-[70vh] flex items-center justify-center">
    <div class="w-full max-w-sm flex flex-col gap-8">

      <div class="flex flex-col gap-3">
        <span class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric">
          // Console
        </span>
        <h1 class="text-3xl font-bold tracking-tight text-cream">
          BLVST<span class="inline-block" aria-hidden="true">Λ</span>CK
        </h1>
        <p class="text-sm text-slate leading-relaxed">
          Sign in to access the operator console.
        </p>
      </div>

      <form method="POST" action="/api/admin/login" class="flex flex-col gap-5">

        <label class="flex flex-col gap-2">
          <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="bg-white/5 border border-white/10 px-4 py-3 text-sm text-cream placeholder-slate/40 focus:outline-none focus:border-electric/60 focus:bg-white/[0.07] transition-colors"
          />
        </label>

        <label class="flex flex-col gap-2">
          <span class="font-mono text-[10px] tracking-widest uppercase text-slate/70">Password</span>
          <input
            type="password"
            name="password"
            required
            autocomplete="current-password"
            class="bg-white/5 border border-white/10 px-4 py-3 text-sm text-cream placeholder-slate/40 focus:outline-none focus:border-electric/60 focus:bg-white/[0.07] transition-colors"
          />
        </label>

        {error && (
          <p class="font-mono text-[11px] tracking-wide text-red-400 -mt-2">
            {error === 'invalid' ? 'Invalid credentials.' : 'Something went wrong.'}
          </p>
        )}

        <button
          type="submit"
          class="bg-electric hover:bg-electric/90 text-cream font-mono text-[11px] tracking-[0.25em] uppercase px-6 py-3.5 transition-colors mt-2"
        >
          Sign in &rarr;
        </button>

      </form>

    </div>
  </section>
</AdminLayout>
