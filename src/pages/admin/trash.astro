---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabaseAdmin } from '../../lib/supabase';

export const prerender = false;

const adminEmail = Astro.locals.adminEmail;

const [{ data: leads = [] }, { data: messages = [] }] = await Promise.all([
  supabaseAdmin
    .from('leads')
    .select('id, name, email, status, deleted_at, created_at')
    .not('deleted_at', 'is', null)
    .order('deleted_at', { ascending: false }),
  supabaseAdmin
    .from('contact_messages')
    .select('id, name, email, message, deleted_at, created_at')
    .not('deleted_at', 'is', null)
    .order('deleted_at', { ascending: false }),
]);

const safeLeads = leads ?? [];
const safeMessages = messages ?? [];
const totalTrashed = safeLeads.length + safeMessages.length;

const tabParam = Astro.url.searchParams.get('tab') ?? 'leads';
const tabs = [
  { key: 'leads',    label: 'Leads',     n: '01', count: safeLeads.length },
  { key: 'messages', label: 'Messages',  n: '02', count: safeMessages.length },
];
const activeTab = tabs.find((t) => t.key === tabParam) ? tabParam : 'leads';

function daysUntilPurge(deletedAt: string): number {
  const purgeAt = new Date(deletedAt).getTime() + 30 * 24 * 60 * 60 * 1000;
  return Math.max(0, Math.ceil((purgeAt - Date.now()) / (24 * 60 * 60 * 1000)));
}

function fmtDate(iso: string): string {
  return new Date(iso).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
---

<AdminLayout title="Trash" adminEmail={adminEmail}>

  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-electric mb-2">
        // Trash
      </p>
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-cream">
        Trash <span class="text-slate text-2xl font-normal">({totalTrashed})</span>
      </h1>
      <p class="mt-3 font-mono text-[11px] tracking-wide text-slate/60">
        Items here are auto-purged 30 days after deletion.
      </p>
    </div>
  </div>

  <!-- Tab strip -->
  <div class="flex border-b border-white/5 mb-8">
    {tabs.map((t) => {
      const isActive = activeTab === t.key;
      return (
        <a
          href={`/admin/trash?tab=${t.key}`}
          class={`group flex items-center gap-3 px-5 py-3 border-b-2 transition-colors -mb-px ${
            isActive ? 'border-electric text-cream' : 'border-transparent text-slate hover:text-cream'
          }`}
        >
          <span class={`font-mono text-[9px] tracking-widest ${
            isActive ? 'text-electric' : 'text-slate/70 group-hover:text-electric'
          }`}>{t.n}</span>
          <span class="font-mono text-[11px] tracking-widest uppercase">{t.label}</span>
          <span class="font-mono text-[10px] text-slate/70">({t.count})</span>
        </a>
      );
    })}
  </div>

  <!-- ════════ LEADS TAB ════════ -->
  {activeTab === 'leads' && (
    safeLeads.length === 0 ? (
      <div class="bg-navy border border-white/5 p-12 text-center">
        <p class="font-mono text-xs text-slate/60">No trashed leads.</p>
      </div>
    ) : (
      <ul class="flex flex-col gap-px bg-white/5">
        {safeLeads.map((l: any) => {
          const days = daysUntilPurge(l.deleted_at);
          return (
            <li class="bg-navy p-5 flex items-center justify-between gap-4" data-trash-row data-table="leads" data-id={l.id} data-name={l.name}>
              <div class="flex flex-col gap-1 min-w-0">
                <span class="text-sm text-cream font-medium truncate">{l.name}</span>
                <span class="font-mono text-[11px] text-slate/60 truncate">{l.email}</span>
                <span class="font-mono text-[10px] text-slate/60 mt-1">
                  Deleted {fmtDate(l.deleted_at)} &middot; purge in {days} day{days === 1 ? '' : 's'}
                </span>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <button data-restore class="font-mono text-[10px] tracking-widest uppercase px-3 py-1.5 border border-white/10 text-slate hover:text-electric hover:border-electric/40 transition-colors">
                  Restore
                </button>
                <button data-purge class="font-mono text-[10px] tracking-widest uppercase px-3 py-1.5 border border-red-500/20 text-red-400/70 hover:text-red-400 hover:border-red-500/50 transition-colors">
                  Delete now
                </button>
              </div>
            </li>
          );
        })}
      </ul>
    )
  )}

  <!-- ════════ MESSAGES TAB ════════ -->
  {activeTab === 'messages' && (
    safeMessages.length === 0 ? (
      <div class="bg-navy border border-white/5 p-12 text-center">
        <p class="font-mono text-xs text-slate/60">No trashed messages.</p>
      </div>
    ) : (
      <ul class="flex flex-col gap-px bg-white/5">
        {safeMessages.map((m: any) => {
          const days = daysUntilPurge(m.deleted_at);
          return (
            <li class="bg-navy p-5" data-trash-row data-table="messages" data-id={m.id} data-name={m.name}>
              <div class="flex items-start justify-between gap-4 mb-3">
                <div class="flex flex-col gap-1 min-w-0">
                  <span class="text-sm text-cream font-medium">{m.name}</span>
                  <span class="font-mono text-[11px] text-slate/60">{m.email}</span>
                  <span class="font-mono text-[10px] text-slate/60 mt-1">
                    Deleted {fmtDate(m.deleted_at)} &middot; purge in {days} day{days === 1 ? '' : 's'}
                  </span>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <button data-restore class="font-mono text-[10px] tracking-widest uppercase px-3 py-1.5 border border-white/10 text-slate hover:text-electric hover:border-electric/40 transition-colors">
                    Restore
                  </button>
                  <button data-purge class="font-mono text-[10px] tracking-widest uppercase px-3 py-1.5 border border-red-500/20 text-red-400/70 hover:text-red-400 hover:border-red-500/50 transition-colors">
                    Delete now
                  </button>
                </div>
              </div>
              <p class="text-sm text-cream/70 leading-relaxed whitespace-pre-wrap border-l-2 border-white/10 pl-4 line-clamp-3">
                {m.message}
              </p>
            </li>
          );
        })}
      </ul>
    )
  )}

  <script>
    document.querySelectorAll<HTMLElement>('[data-trash-row]').forEach((row) => {
      const table = row.dataset.table;
      const id = row.dataset.id;
      const name = row.dataset.name ?? 'this item';

      row.querySelector<HTMLButtonElement>('[data-restore]')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/admin/${table}/${id}?restore=true`, { method: 'POST' });
          if (!res.ok) throw new Error('Failed');
          window.location.reload();
        } catch {
          btn.disabled = false;
          btn.textContent = 'Failed';
        }
      });

      row.querySelector<HTMLButtonElement>('[data-purge]')?.addEventListener('click', async (e) => {
        const btn = e.currentTarget as HTMLButtonElement;
        if (!confirm(`Permanently delete ${name}? This cannot be undone.`)) return;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/admin/${table}/${id}?permanent=true`, { method: 'DELETE' });
          if (!res.ok) throw new Error('Failed');
          window.location.reload();
        } catch {
          btn.disabled = false;
          btn.textContent = 'Failed';
        }
      });
    });
  </script>

</AdminLayout>
