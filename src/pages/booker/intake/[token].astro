---
import BookerLayout from '../../../layouts/BookerLayout.astro';
import { supabaseAdmin } from '../../../lib/supabase';

export const prerender = false;

const { token } = Astro.params;

const { data: artist } = await supabaseAdmin
  .from('booker_artists')
  .select('id, name, stage_name, email, performer_type, performer_types, intake_completed_at, intake_expires_at, deleted_at')
  .eq('intake_token', token ?? '')
  .single();

if (!artist || artist.deleted_at) {
  return Astro.redirect('/404');
}

const completed = !!artist.intake_completed_at;
const expired =
  !completed &&
  !!artist.intake_expires_at &&
  new Date(artist.intake_expires_at).getTime() < Date.now();

const firstName = artist.stage_name?.split(' ')[0] ?? artist.name?.split(' ')[0] ?? 'there';

const performerOptions = [
  { value: 'dj',            label: 'DJ' },
  { value: 'rapper',        label: 'Rapper' },
  { value: 'singer',        label: 'Singer' },
  { value: 'band',          label: 'Band' },
  { value: 'musician',      label: 'Musician' },
  { value: 'poet',          label: 'Poet' },
  { value: 'visual_artist', label: 'Visual artist' },
  { value: 'other',         label: 'Other' },
];

const gigTypeOptions = ['weddings', 'clubs', 'corporate', 'private', 'festivals', 'open_mics', 'college', 'restaurants'];
---

<BookerLayout title="Intake" description="Set up your booking profile so we can match you to gigs.">

  <!-- Header strip -->
  <header style="padding: 32px 24px 0 24px;">
    <div style="max-width: 560px; margin: 0 auto;">
      <img
        src="/blvbooker-brand/blvbooker-logo-transparent.svg"
        alt="BLVBooker"
        style="width: 160px; height: auto; display: block; margin-bottom: 8px;"
      />
      <p style="font-family: var(--bk-font-mono); font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase; color: var(--bk-indigo);">
        Bookings, handled.
      </p>
    </div>
  </header>

  <main style="padding: 32px 24px 80px 24px;">
    <div style="max-width: 560px; margin: 0 auto;">

      {expired ? (
        <>
          <p class="bk-eyebrow">// Roster intake</p>
          <h1 style="margin-bottom: 16px;">This link expired, {firstName}.</h1>
          <p class="bk-muted" style="margin-bottom: 12px;">
            For security, intake links are good for 14 days. This one passed its window.
          </p>
          <p class="bk-muted">
            Reply to the email you got, or contact your agent — they'll send a fresh link in seconds.
          </p>
        </>
      ) : completed ? (
        <>
          <p class="bk-eyebrow">// Profile saved</p>
          <h1 style="margin-bottom: 16px;">You're all set, {firstName}.</h1>
          <p class="bk-muted" style="margin-bottom: 12px;">
            Your profile is in. We'll start matching you to gigs and pitching venues that fit. You'll only hear from us when we find something real.
          </p>
          <p class="bk-faint" style="margin-bottom: 24px;">Keep this link to update your profile any time.</p>
          <button id="btn-edit" class="bk-btn bk-btn-secondary">Edit profile</button>
        </>
      ) : (
        <>
          <p class="bk-eyebrow">// Roster intake</p>
          <h1 style="margin-bottom: 16px;">Hey {firstName} — let's get your bookings flowing.</h1>
          <p class="bk-muted" style="margin-bottom: 8px;">
            Quick form. About 5 minutes. The more specific, the better we can match you.
          </p>
          {artist.intake_expires_at && (
            <p class="bk-faint">
              Link expires {new Date(artist.intake_expires_at).toLocaleDateString()}.
            </p>
          )}
        </>
      )}

      <form id="intake-form" style={`display: ${expired || completed ? 'none' : 'flex'}; flex-direction: column; gap: 24px; margin-top: 32px;`}>

        <!-- Identity -->
        <section class="bk-card">
          <p class="bk-eyebrow">// Identity</p>
          <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px;">
            <label>
              <span class="bk-label">Stage / performer name</span>
              <input name="stage_name" value={artist.stage_name ?? ''} required class="bk-input" />
            </label>
            <label>
              <span class="bk-label">Legal name (for contracts)</span>
              <input name="name" value={artist.name ?? ''} class="bk-input" />
            </label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <label>
                <span class="bk-label">Email</span>
                <input type="email" name="email" value={artist.email ?? ''} required class="bk-input" />
              </label>
              <label>
                <span class="bk-label">Phone</span>
                <input id="phone-input" name="phone" type="tel" inputmode="numeric" maxlength="12" placeholder="555-123-4567" class="bk-input" />
              </label>
            </div>
            <div>
              <span class="bk-label">What kind of performer? (check all that apply)</span>
              <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
                {performerOptions.map((pt) => (
                  <label class="bk-checkbox-tile">
                    <input type="checkbox" name="performer_types" value={pt.value} />
                    <span class="bk-checkbox-tile-label">{pt.label}</span>
                  </label>
                ))}
              </div>
            </div>
          </div>
        </section>

        <!-- Location & Travel -->
        <section class="bk-card">
          <p class="bk-eyebrow">// Location & Travel</p>
          <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px;">
            <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 16px;">
              <label>
                <span class="bk-label">City</span>
                <input name="city" class="bk-input" />
              </label>
              <label>
                <span class="bk-label">State</span>
                <input name="region" maxlength="2" class="bk-input" />
              </label>
            </div>
            <label>
              <span class="bk-label">Travel radius (miles)</span>
              <input type="number" name="travel_radius_mi" placeholder="e.g. 100" class="bk-input" style="max-width: 160px;" />
            </label>
            <label>
              <span class="bk-label">Availability notes</span>
              <textarea name="availability_notes" rows="2" placeholder="e.g. weekends only, no Sunday mornings, blackout dates…" class="bk-textarea"></textarea>
            </label>
          </div>
        </section>

        <!-- Style & Rates -->
        <section class="bk-card">
          <p class="bk-eyebrow">// Style & Rates</p>
          <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px;">
            <label>
              <span class="bk-label">Genres / style</span>
              <input name="genres" placeholder="e.g. house, techno / spoken word, slam / acoustic singer-songwriter" class="bk-input" />
            </label>
            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 16px;">
              <label>
                <span class="bk-label">Rate floor</span>
                <div style="position: relative;">
                  <span style="position: absolute; left: 14px; top: 50%; transform: translateY(-50%); color: var(--bk-text-muted); font-family: var(--bk-font-sans); font-size: 15px; pointer-events: none;">$</span>
                  <input type="number" name="rate_floor" inputmode="numeric" min="0" step="50" placeholder="500" class="bk-input" style="padding-left: 28px;" />
                </div>
                <p class="bk-helper">Minimum USD per gig.</p>
              </label>
              <label>
                <span class="bk-label">Rate notes</span>
                <input name="rate_notes" placeholder="e.g. higher for weddings" class="bk-input" />
              </label>
            </div>
            <div>
              <span class="bk-label">Gig types you want</span>
              <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
                {gigTypeOptions.map((g) => (
                  <label class="bk-checkbox-tile">
                    <input type="checkbox" name="gig_types" value={g} />
                    <span class="bk-checkbox-tile-label">{g.replace(/_/g, ' ')}</span>
                  </label>
                ))}
              </div>
            </div>
          </div>
        </section>

        <!-- Bio & Links -->
        <section class="bk-card">
          <p class="bk-eyebrow">// Bio & Links</p>
          <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 16px;">
            <label>
              <span class="bk-label">Short bio</span>
              <textarea name="bio" rows="4" placeholder="2–3 sentences. What makes you you?" class="bk-textarea"></textarea>
            </label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <label>
                <span class="bk-label">Press kit URL</span>
                <input name="press_kit_url" type="url" placeholder="https://…" class="bk-input" />
              </label>
              <label>
                <span class="bk-label">Demo / sample URL</span>
                <input name="demo_url" type="url" placeholder="SoundCloud, YouTube, Spotify…" class="bk-input" />
              </label>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
              <label>
                <span class="bk-label">Instagram</span>
                <input name="instagram" placeholder="@handle or URL" class="bk-input" />
              </label>
              <label>
                <span class="bk-label">TikTok</span>
                <input name="tiktok" placeholder="@handle or URL" class="bk-input" />
              </label>
              <label>
                <span class="bk-label">Spotify</span>
                <input name="spotify" placeholder="Artist URL" class="bk-input" />
              </label>
              <label>
                <span class="bk-label">SoundCloud</span>
                <input name="soundcloud" placeholder="Profile URL" class="bk-input" />
              </label>
              <label>
                <span class="bk-label">YouTube</span>
                <input name="youtube" placeholder="Channel URL" class="bk-input" />
              </label>
              <label>
                <span class="bk-label">Website</span>
                <input name="website" placeholder="https://…" class="bk-input" />
              </label>
            </div>

            <div>
              <span class="bk-label">Other links (optional — BandCamp, Patreon, Linktree, press features, etc.)</span>
              <div style="display: flex; flex-direction: column; gap: 8px;">
                {Array.from({ length: 5 }, (_, i) => (
                  <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 8px;">
                    <input name={`extra_label_${i}`} placeholder="Platform / label" class="bk-input" />
                    <input name={`extra_url_${i}`} type="url" placeholder="https://…" class="bk-input" />
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>

        <!-- Hard nos -->
        <section class="bk-card">
          <p class="bk-eyebrow">// Hard Nos</p>
          <label style="display: block; margin-top: 16px;">
            <span class="bk-label">What you won't do</span>
            <textarea name="hard_nos" rows="2" placeholder="e.g. no kids' parties, no overnight drives, no requests for X genre…" class="bk-textarea"></textarea>
          </label>
        </section>

        <div style="display: flex; align-items: center; gap: 16px;">
          <button type="submit" class="bk-btn">Submit profile</button>
          <span id="submit-status" class="bk-helper" style="margin-top: 0;"></span>
        </div>
      </form>

    </div>
  </main>

</BookerLayout>

<script define:vars={{ token, formInitialHidden: completed || expired }}>
  // Phone field — live-format as US ###-###-#### while typing
  (function() {
    const el = document.getElementById('phone-input');
    if (!el) return;
    const format = (s) => {
      const d = (s || '').replace(/\D/g, '').slice(0, 10);
      if (d.length < 4) return d;
      if (d.length < 7) return `${d.slice(0,3)}-${d.slice(3)}`;
      return `${d.slice(0,3)}-${d.slice(3,6)}-${d.slice(6)}`;
    };
    el.addEventListener('input', () => {
      const before = el.value;
      const after = format(before);
      if (before !== after) {
        const caret = el.selectionStart ?? after.length;
        el.value = after;
        if (caret >= before.length) el.setSelectionRange(after.length, after.length);
      }
    });
  })();

  document.getElementById('btn-edit')?.addEventListener('click', () => {
    document.getElementById('intake-form').style.display = 'flex';
  });

  document.getElementById('intake-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const status = document.getElementById('submit-status');
    if (status) status.textContent = 'Submitting…';

    const form = e.target;
    const fd = new FormData(form);
    const body = {};
    const gigTypes = [];
    const performerTypes = [];
    const socialLinks = {};

    // Collect extra label+URL pairs (custom links) before main pass.
    // Auto-suffix on collision so multiple "YouTube" extras become youtube_2, youtube_3
    // instead of overwriting each other.
    function slugify(s) {
      return s.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '').slice(0, 40) || 'link';
    }
    function uniqueKey(base, taken) {
      if (!taken.has(base)) return base;
      let i = 2;
      while (taken.has(`${base}_${i}`)) i++;
      return `${base}_${i}`;
    }
    const extras = {};
    const extrasTaken = new Set();
    for (let i = 0; i < 5; i++) {
      const label = (fd.get(`extra_label_${i}`) || '').toString().trim();
      const url = (fd.get(`extra_url_${i}`) || '').toString().trim();
      if (label && url) {
        const key = uniqueKey(slugify(label), extrasTaken);
        extras[key] = url;
        extrasTaken.add(key);
      }
    }

    fd.forEach((value, key) => {
      const v = value.toString().trim();
      if (!v) return;
      if (key === 'gig_types') { gigTypes.push(v); return; }
      if (key === 'performer_types') { performerTypes.push(v); return; }
      if (key.startsWith('extra_label_') || key.startsWith('extra_url_')) return; // handled above
      if (['instagram', 'spotify', 'tiktok', 'soundcloud', 'youtube', 'website'].includes(key)) {
        socialLinks[key] = v; return;
      }
      if (key === 'travel_radius_mi' || key === 'rate_floor') {
        body[key] = parseInt(v, 10); return;
      }
      body[key] = v;
    });

    // Merge extras into socialLinks. If an extra's slug collides with a named
    // social (e.g. extra labeled "YouTube" when named YouTube already filled),
    // auto-suffix it (youtube_2, youtube_3…) so nothing gets dropped.
    const allTaken = new Set(Object.keys(socialLinks));
    for (const [k, v] of Object.entries(extras)) {
      const key = uniqueKey(k, allTaken);
      socialLinks[key] = v;
      allTaken.add(key);
    }

    if (gigTypes.length > 0) body.gig_types = gigTypes;
    if (performerTypes.length > 0) body.performer_types = performerTypes;
    if (Object.keys(socialLinks).length > 0) body.social_links = socialLinks;

    try {
      const res = await fetch(`/api/booker/intake/${token}`, {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body),
      });
      const json = await res.json();
      if (res.ok) {
        if (status) status.textContent = 'Submitted. Reloading…';
        setTimeout(() => window.location.reload(), 800);
      } else {
        if (status) status.textContent = json.error ?? 'Submit failed';
      }
    } catch {
      if (status) status.textContent = 'Network error';
    }
  });
</script>
